# Based on github/gitignore (macOS + Bash + Swift + common editor/tooling)
# https://github.com/github/gitignore

# ────────────────────────────────────────────────────────────────────────────
# Swift / SwiftPM build artifacts — pager/ subdir hosts the companion Mac app.
# Mirrors github.com/github/gitignore/blob/main/Swift.gitignore.
# ────────────────────────────────────────────────────────────────────────────
pager/.build/
pager/.swiftpm/
pager/Packages/
pager/Package.resolved
pager/build/
pager/DerivedData/
pager/*.xcodeproj/

# ────────────────────────────────────────────────────────────────────────────
# Project secrets and runtime state (most important — never commit these)
# ────────────────────────────────────────────────────────────────────────────
# Local environment / credentials (use .env.example as the template)
.env
.env.local
.env.*.local
# Telethon/MTProto session strings are LIVE credentials — never commit.
*.session
*.session-journal

# Local-only helpers / internal research that must not ship in the public repo.
# (Untracked today; listed so `git add -A` can't sweep them in.) Force with -f
# if you ever decide to publish one.
/research/
/generate_session_qr.py

# Runtime logs and backups
*.log
logs/
*.bak
*.orig

# Pre-commit hook scratch
/tmp/precommit-hit.*

# Session scratchpads — prompts handed to other tools (Comet, etc.), never tracked.
/.tmp/

# ────────────────────────────────────────────────────────────────────────────
# macOS — https://github.com/github/gitignore/blob/main/Global/macOS.gitignore
# ────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ────────────────────────────────────────────────────────────────────────────
# Editors / IDEs
# ────────────────────────────────────────────────────────────────────────────
# vim / nvim
*.swp
*.swo
*.swn
Session.vim
.netrwhist
tags

# VS Code (keep .vscode/settings.json if it ever gets shared; ignore the rest)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains
.idea/
*.iml

# Sublime / TextMate
*.sublime-workspace
*.tmproj

# Emacs
*~
\#*\#
.\#*
.dir-locals.el

# ────────────────────────────────────────────────────────────────────────────
# Tooling — anything that might land here later
# ────────────────────────────────────────────────────────────────────────────
# Ruby / bundler (if fastlane or similar gets added)
vendor/bundle/
.bundle/
Gemfile.lock

# Node (very unlikely but defensive)
node_modules/
npm-debug.log
yarn-error.log

# Python (defensive)
__pycache__/
*.py[cod]
.venv/
.python-version

# AI / coding assistants (don't leak local notes)
.cursor/
.cursorignore
.windsurf/
.continue/
.aider*

# Claude Code auto-memory. The real files live at
# ~/.claude/projects/-<encoded-cwd>/memory/ (auto-memory home); the
# in-repo `memory` is a symlink there for convenience. Contains personal
# context — never commit to the OSS repo. No trailing slash so the rule
# also matches the symlink itself, not just a real directory.
/memory
/.claude/scheduled_tasks.lock
.playwright-mcp/
HEARTBEAT.md

# Internal planning docs — kept local, never published.
/docs/plans/
