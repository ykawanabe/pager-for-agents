<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>__BIN_DIR__/start_agents.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- PATH must include:
             - ~/.bun/bin — bun (Telegram plugin spawns `bun run …`; if missing,
               the channel silently fails to start)
             - /opt/homebrew/bin — Apple Silicon Homebrew (tmux, etc.)
             - /usr/local/bin — Intel Homebrew (tmux, etc.)
             so the same plist works on both architectures. -->
        <key>PATH</key>
        <string>__HOME__/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:__HOME__/.local/bin</string>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>

    <key>StandardOutPath</key>
    <string>__HOME__/.claude-telegram-agent/agent.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/.claude-telegram-agent/agent.err.log</string>
</dict>
</plist>
