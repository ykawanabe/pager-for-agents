#!/bin/bash
# cta — claude-telegram-agent CLI.
#
# The single source of truth for "what is the agent doing right now?" and
# "start / stop the agent". Pager and any future UI call this instead of
# re-implementing process detection. As long as the JSON schema below stays
# backward-compatible, agent-side changes (rename a tmux session, switch
# plugin runtime, move a file) don't break the UI.
#
# Schema (cta status --json):
#   {
#     "schema_version": 1,
#     "launch_agent": {"label": "com.claude-agent", "loaded": true|false},
#     "claude":       {"pid": <int>|null, "rss_mb": <int>|null},
#     "telegram_mcp": {"alive": true|false},
#     "tmux": {
#       "claude":   {"name": "<session>", "alive": true|false},
#       "watchdog": {"name": "<session>", "alive": true|false}
#     },
#     "last_activity": "<ISO8601>" | null,
#     "file_access": {"protected_ok": bool, "probed_path": "...", "checked_at": "<ISO8601>"} | null
#   }
#
# Bumps to schema_version are reserved for breaking changes (F1+F2 multi-topic
# will introduce schema_version=2 with a per-topic array). Additive fields
# stay at the current version.
set -uo pipefail

# When invoked from a launchd-spawned process (Claude Pager via CTAClient,
# or the LaunchAgent's own restart cycle), $PATH is stripped to the macOS
# default: /usr/bin:/bin:/usr/sbin:/sbin. bun lives in ~/.bun/bin and the
# Homebrew tools (pgrep is /usr/bin, but launchctl probes + bun resolution
# need the augmented set) live in /opt/homebrew/bin (Apple Silicon) or
# /usr/local/bin (Intel) — none in the stripped PATH. Without this prepend,
# child commands silently fail with "command not found" and cta misreports
# liveness. Prepend rather than overwrite so any caller-set PATH still wins
# for entries we don't list.
export PATH="$HOME/.bun/bin:/opt/homebrew/bin:/usr/local/bin:${PATH:-/usr/bin:/bin}:$HOME/.local/bin"

PLIST_LABEL="com.claude-agent"
PLIST_PATH="$HOME/Library/LaunchAgents/${PLIST_LABEL}.plist"
# P6c: the network/heartbeat watchdog is its own launchd job (was a tmux
# session). Both jobs are loaded/booted together by cta start/stop.
WATCHDOG_LABEL="com.claude-watchdog"
WATCHDOG_PLIST_PATH="$HOME/Library/LaunchAgents/${WATCHDOG_LABEL}.plist"
BOT_PID_FILE="$HOME/.claude/channels/telegram/bot.pid"
ACCESS_FILE="$HOME/.claude/channels/telegram/access.json"

# State + install dirs. Defaults match agent/lib/paths.ts. Env overrides
# (CTA_STATE_DIR / CTA_INSTALL_DIR) flow through here so a single shell can
# point both the CLI and the agent at the same custom location.
STATE_DIR="${CTA_STATE_DIR:-$HOME/.pager}"
INSTALL_DIR="${CTA_INSTALL_DIR:-$HOME/.local/share/pager}"
LEGACY_STATE_DIR="$HOME/.claude-telegram-agent"
LEGACY_INSTALL_DIR="$HOME/.local/share/claude-telegram-agent"

# All state-file paths MUST derive from $STATE_DIR. Hardcoding $HOME/.claude-telegram-agent/...
# anywhere outside cmd_migrate_state diverges from agent/lib/paths.ts (which uses
# stateDir() = ~/.pager) and causes silent mismatches — e.g., poller writes to ~/.pager,
# cta reads from the legacy dir, /pair fails with "Pairing code did not match".
# Regression test in tests/test_cta.sh guards this.
ENV_FILE="$STATE_DIR/.env"
CAFFEINATE_PID_FILE="$STATE_DIR/caffeinate.pid"
SETTINGS_FILE="$STATE_DIR/settings.json"
PAIRING_CODE_FILE="$STATE_DIR/pairing-code"
PAIRED_STATE_FILE="$STATE_DIR/paired.json"
# shellcheck disable=SC2034  # not read by cta directly; kept as a state-path the tests/test_cta.sh guard verifies resolves from $STATE_DIR
MOUNTS_FILE="$STATE_DIR/mounts.json"
TOPICS_FILE="$STATE_DIR/topics.json"
MOUNT_STORE_TS="$INSTALL_DIR/agent/mount-store/mount-store.ts"

# Default emoji used by `cta config ack on`. Must be in Telegram's free-bot
# reaction whitelist — eyes reads as "seen" and is universally available.
# Kept in sync with Pager's kDefaultAckEmoji (SettingsView.swift) so the two
# UIs agree on what "on" means.
DEFAULT_ACK_EMOJI="👀"

# Load .env early so configurable session names take effect. Falls back to
# defaults if .env doesn't exist yet (e.g., before install.sh has run).
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$ENV_FILE"
  set +a
fi
TMUX_SESSION_CLAUDE="${TMUX_SESSION_CLAUDE:-claude}"
TMUX_SESSION_WATCHDOG="${TMUX_SESSION_WATCHDOG:-watchdog}"

# MULTI_TOPIC mode replaces the v0 `claude` tmux session with `poller` + N
# `topic-<thread_id>` sessions. Status checks delegate to those instead so
# Pager doesn't keep reporting "claude=✗" forever.
_multi_topic_enabled() {
  [[ "${MULTI_TOPIC:-0}" == "1" ]]
}

# ─── helpers ─────────────────────────────────────────────────────────────────

# Atomic single-arg form. The piped `launchctl list | grep -q LABEL` shape
# under `set -uo pipefail` flips false ~8% of polls under I/O load: grep -q
# closes its stdin on first match, launchctl is still streaming over IPC,
# gets SIGPIPE, pipeline returns non-zero, Pager sees a false Degraded.
_la_loaded() {
  launchctl list "$PLIST_LABEL" >/dev/null 2>&1
}

# Print "<pid> <rss_kb>" for the canonical always-on process, else empty line.
# Phase 4 (daemon mode): the long-lived process is the POLLER (bun) — claude
# spawns lazily inside it per topic and only exists during a turn, so grepping
# for `claude --mcp-config` returns empty between turns and flickers the Pager
# status to red. Match the poller bun process instead.
# MULTI_TOPIC (legacy stream-json mode without daemons): same poller match.
# Single-topic v0: the old `claude --channels` grep.
_claude_ps_line() {
  local pat
  if _multi_topic_enabled; then
    # Anchored to `/poller.ts$` so a dev's `bun test agent/poller/poller.ts`
    # doesn't get picked up. Same anchor as cmd_stop's pgrep.
    pat="bun .*/agent/poller/poller\.ts$"
  else
    pat="claude --channels plugin:telegram"
  fi
  # Local `set +o pipefail`: the head -1 / grep chain can SIGPIPE the upstream
  # ps under load and flip pipefail to non-zero, which would empty out the
  # claude.pid field in cta status. Same family of bug as _la_loaded's old form.
  # shellcheck disable=SC2009  # pgrep doesn't expose rss + we need pid+rss in one shot
  ( set +o pipefail
    ps -Ao pid=,rss=,command= 2>/dev/null \
      | grep -E "$pat" \
      | grep -v grep \
      | head -1 \
      | awk '{print $1, $2}'
  )
}

# Outbound liveness: "can the bot send a message to Telegram right now?"
#
# Daemon mode (P4+): the poller sends every reply directly via Bot API HTTP.
# There's no separate outbound process to probe, so the honest answer to
# "is outbound alive?" is "is the poller alive?" — same liveness as the
# daemon. `_mcp_alive` is kept only as a back-compat name for the status
# JSON field Pager still reads; in MULTI_TOPIC mode it pgreps the poller.
#
# v0 / pre-Phase-4: the official plugin's persistent bun server.ts was
# the canonical outbound process; grep for it.
_mcp_alive() {
  if _multi_topic_enabled; then
    pgrep -f 'bun .*/agent/poller/poller\.ts$' >/dev/null 2>&1
  else
    pgrep -f "bun.*server.ts" >/dev/null 2>&1
  fi
}

# P6c: liveness is process-based now, not tmux-session-based. The poller and
# the watchdog each run as a launchd-direct process; pgrep their argv.
# `bun .../agent/poller/poller.ts$` is anchored so a dev's `bun test …poller.ts`
# isn't mistaken for the live poller (same anchor as _claude_ps_line/cmd_stop).
_poller_alive() {
  pgrep -f 'bun .*/agent/poller/poller\.ts$' >/dev/null 2>&1
}
_watchdog_alive() {
  pgrep -f 'watch_network\.sh' >/dev/null 2>&1
}

# Returns ISO8601 mtime of the most recent activity signal.
# Phase 4: $STATE_DIR/heartbeat-poller is touched every getUpdates cycle
# (~25-30s under normal long-poll). It's the right "last seen alive" signal
# in daemon mode where there's no v0 bot.pid heartbeat.
# v0 fallback: bot.pid mtime when the heartbeat file isn't there yet.
_last_activity() {
  local hb="$STATE_DIR/heartbeat-poller"
  if [[ -f "$hb" ]]; then
    TZ=UTC stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' "$hb" 2>/dev/null || true
    return 0
  fi
  [[ -f "$BOT_PID_FILE" ]] || return 0
  TZ=UTC stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' "$BOT_PID_FILE" 2>/dev/null || true
}

# Emit a JSON literal for an integer-or-null. Empty input → "null", else the
# integer itself. No quoting (JSON numbers are bare).
_json_int_or_null() {
  if [[ -z "$1" ]]; then
    printf 'null'
  else
    printf '%s' "$1"
  fi
}

# Emit a JSON literal for a string-or-null. Empty → "null", else "<escaped>".
# Escapes the two characters that can break a JSON string literal in practice
# here: backslash and double-quote. Newlines and control chars don't appear
# in any of our sources (process names, label strings, ISO dates).
_json_str_or_null() {
  if [[ -z "$1" ]]; then
    printf 'null'
  else
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    printf '"%s"' "$s"
  fi
}

_json_bool() {
  if "$@"; then printf 'true'; else printf 'false'; fi
}

# ─── commands ────────────────────────────────────────────────────────────────

cmd_status() {
  local format="${1:-text}"

  local la_loaded
  if _la_loaded; then la_loaded=true; else la_loaded=false; fi

  local ps_line pid="" rss_kb=""
  ps_line=$(_claude_ps_line)
  if [[ -n "$ps_line" ]]; then
    pid="${ps_line%% *}"
    rss_kb="${ps_line##* }"
  fi

  local mcp_alive
  if _mcp_alive; then mcp_alive=true; else mcp_alive=false; fi

  # P6c: tmux is gone, but the JSON `tmux` object is retained for back-compat
  # (Pager + any scripts read tmux.claude.alive / tmux.watchdog.alive). The
  # `.alive` fields now report launchd-process liveness (poller / watchdog),
  # and the `.name` fields keep their display labels. In MULTI_TOPIC mode the
  # control label is "poller" (the v0 `claude` session never existed there).
  local control_session
  if _multi_topic_enabled; then control_session="poller"
  else control_session="$TMUX_SESSION_CLAUDE"
  fi
  local tmux_claude tmux_watchdog
  if _poller_alive;   then tmux_claude=true;   else tmux_claude=false;   fi
  if _watchdog_alive; then tmux_watchdog=true; else tmux_watchdog=false; fi

  local activity
  activity=$(_last_activity)

  local caffeinate_pid="" caffeinate_alive
  if _caffeinate_alive; then
    caffeinate_alive=true
    caffeinate_pid=$(cat "$CAFFEINATE_PID_FILE" 2>/dev/null)
  else
    caffeinate_alive=false
  fi

  # File-access (FDA) probe result, written by the poller in the launchd TCC
  # context ($STATE_DIR/file-access.json). cta is the WRONG context to probe, so
  # we only surface what the poller recorded. Absent → null (older agents).
  local file_access="null"
  if [[ -f "$STATE_DIR/file-access.json" ]]; then
    file_access=$(cat "$STATE_DIR/file-access.json")
  fi

  if [[ "$format" == "json" ]]; then
    local rss_mb=""
    [[ -n "$rss_kb" ]] && rss_mb=$(( rss_kb / 1024 ))
    cat <<EOF
{
  "schema_version": 1,
  "launch_agent": {"label": $(_json_str_or_null "$PLIST_LABEL"), "loaded": $la_loaded},
  "claude": {"pid": $(_json_int_or_null "$pid"), "rss_mb": $(_json_int_or_null "$rss_mb")},
  "telegram_mcp": {"alive": $mcp_alive},
  "tmux": {
    "claude": {"name": $(_json_str_or_null "$control_session"), "alive": $tmux_claude},
    "watchdog": {"name": $(_json_str_or_null "$TMUX_SESSION_WATCHDOG"), "alive": $tmux_watchdog}
  },
  "caffeinate": {"alive": $caffeinate_alive, "pid": $(_json_int_or_null "$caffeinate_pid")},
  "last_activity": $(_json_str_or_null "$activity"),
  "file_access": $file_access
}
EOF
  else
    printf 'LaunchAgent (%s): %s\n' "$PLIST_LABEL" "$la_loaded"
    printf 'claude PID:       %s\n' "${pid:-(none)}"
    if [[ -n "$rss_kb" ]]; then
      printf 'claude RSS:       %s MB\n' "$(( rss_kb / 1024 ))"
    fi
    printf 'Telegram MCP:     %s\n' "$mcp_alive"
    printf 'Poller:           %s\n' "$tmux_claude"
    printf 'Watchdog:         %s\n' "$tmux_watchdog"
    if [[ "$caffeinate_alive" == "true" ]]; then
      printf 'Caffeinate:       %s (pid %s)\n' "$caffeinate_alive" "$caffeinate_pid"
    else
      printf 'Caffeinate:       %s\n' "$caffeinate_alive"
    fi
    printf 'Last activity:    %s\n' "${activity:-(none)}"
  fi
}

cmd_start() {
  # P6c: launchd-direct. Both jobs (poller + watchdog) are launchd-supervised;
  # `cta start` just ensures they're loaded and running. This is idempotent and
  # NON-DESTRUCTIVE: `launchctl load` of an already-loaded job is a no-op, and a
  # healthy (alive) poller is never restarted. Pager's ensureBotRunning() calls
  # this on every launch — the old tmux path took the bot offline for ~3s here.
  local loaded_any=0
  local plist
  for plist in "$PLIST_PATH" "$WATCHDOG_PLIST_PATH"; do
    if [[ -f "$plist" ]]; then
      launchctl load "$plist" 2>/dev/null || true
      loaded_any=1
    else
      # A missing plist means supervision is incomplete (e.g. an upgrade that
      # didn't re-run install.sh — the watchdog gives no hang-recovery without
      # its job). Warn rather than silently report health.
      echo "Warning: $(basename "$plist") not found — run install.sh to (re)install it." >&2
    fi
  done
  if [[ "$loaded_any" -eq 0 ]]; then
    echo "Missing LaunchAgent plists — run install.sh first." >&2
    return 1
  fi
  # If a job is loaded but not actually running (e.g. it exited 0 and KeepAlive
  # left it down, or `launchctl load` no-op'd because it was already loaded but
  # stopped), kick it. `kickstart` (no -k) starts a stopped job; we gate on
  # liveness so a healthy poller is never force-restarted.
  local uid
  uid=$(id -u)
  if ! _poller_alive; then
    launchctl kickstart "gui/$uid/$PLIST_LABEL" 2>/dev/null || true
  fi
  if ! _watchdog_alive; then
    launchctl kickstart "gui/$uid/$WATCHDOG_LABEL" 2>/dev/null || true
  fi
  echo "Started agent (launchd: $PLIST_LABEL + $WATCHDOG_LABEL)."
}

cmd_stop() {
  # P6c: launchd-direct. Boot out BOTH jobs. `launchctl unload` removes the job
  # (disabling KeepAlive so the poller won't be respawned) AND sends SIGTERM to
  # the running process — letting the poller's shutdown handler flush each
  # daemon's JSONL + release its ~/.claude/tasks/<uuid>/.lock cleanly. Unload
  # the poller FIRST: doing it before the belt-and-suspenders SIGTERM below
  # means a still-running poller can't be respawned by KeepAlive mid-shutdown.
  local plist
  for plist in "$PLIST_PATH" "$WATCHDOG_PLIST_PATH"; do
    if [[ -f "$plist" ]]; then
      launchctl unload "$plist" 2>/dev/null || true
    fi
  done

  # Belt-and-suspenders: if a poller is still alive (started outside launchd, or
  # unload's SIGTERM raced), SIGTERM it and wait for a graceful exit. Match only
  # `bun … /agent/poller/poller.ts` as the LAST argv element so a dev's
  # `bun test agent/poller/poller.ts` isn't signalled. pgrep on macOS supports
  # POSIX regex; anchor with `$`.
  local poller_pids
  poller_pids=$(pgrep -f 'bun .*/agent/poller/poller\.ts$' 2>/dev/null || true)
  if [[ -n "$poller_pids" ]]; then
    # shutdown() awaits each daemon's close with a 5s SIGKILL escalation, so 8s
    # is the upper bound. Run kill loosely so a race can't fail the whole cmd.
    while IFS= read -r pid; do
      kill -TERM "$pid" 2>/dev/null || true
    done <<< "$poller_pids"
    local waited=0
    while [[ "$waited" -lt 80 ]]; do
      if ! pgrep -f 'bun .*/agent/poller/poller\.ts' >/dev/null 2>&1; then break; fi
      sleep 0.1
      waited=$((waited + 1))
    done
  fi

  # Clean up the bun MCP grandchildren a legacy (pre-P4) telegram plugin install
  # may have spawned. They reparent to launchd and keep long-polling getUpdates;
  # the next `cta start` would then race two getUpdates consumers and silently
  # drop ~half of inbound messages. Targeted by command-line match against the
  # plugin path so we never kill an unrelated `bun server.ts` the user runs.
  _kill_plugin_bun
  echo "Stopped agent (launchd: $PLIST_LABEL + $WATCHDOG_LABEL + plugin MCP)."
}

# Kill the telegram plugin's bun wrapper + its server.ts child, but nothing
# else. Identifies victims by command-line match against the plugin path,
# then prunes children via pgrep -P so we don't accidentally kill an
# unrelated `bun server.ts` running in another project on this Mac.
_kill_plugin_bun() {
  local wrappers w kids k
  wrappers=$(pgrep -f "claude-plugins-official.*telegram.*start" 2>/dev/null || true)
  for w in $wrappers; do
    kids=$(pgrep -P "$w" 2>/dev/null || true)
    for k in $kids; do
      kill "$k" 2>/dev/null || true
    done
    kill "$w" 2>/dev/null || true
  done
}

# Toggle the bot's per-message ack reaction by mutating access.json.
# The plugin re-reads access.json on every request (`loadAccess()` in
# server.ts), so the change takes effect on the next inbound message —
# no bot restart needed.
#   cta config ack on   → write "ackReaction": "<DEFAULT_ACK_EMOJI>"
#   cta config ack off  → remove the "ackReaction" key entirely
# Uses python3 (ships with macOS) for JSON mutation so we don't hand-roll
# a JSON parser in bash and don't add a jq dependency.
cmd_config() {
  local sub="${1:-}"
  shift 2>/dev/null || true
  case "$sub" in
    ack)        _config_ack "${1:-}" ;;
    caffeinate) _config_caffeinate "${1:-}" ;;
    idle-evict) _config_idle_evict "${1:-}" ;;
    interrupt-steer) _config_interrupt_steer "${1:-}" ;;
    "")
      echo "Usage: cta config <ack|caffeinate|idle-evict|interrupt-steer> <value>" >&2
      return 1
      ;;
    *)
      echo "Unknown config subcommand: $sub" >&2
      echo "Usage: cta config <ack|caffeinate|idle-evict|interrupt-steer> <value>" >&2
      return 1
      ;;
  esac
}

_config_ack() {
  local val="${1:-}"
  case "$val" in
    on|off) ;;
    "")
      echo "Usage: cta config ack <on|off>" >&2
      return 1
      ;;
    *)
      echo "Invalid value: $val (expected 'on' or 'off')" >&2
      return 1
      ;;
  esac
  if [[ ! -f "$ACCESS_FILE" ]]; then
    echo "Missing $ACCESS_FILE — run install.sh first." >&2
    return 1
  fi
  local emoji=""
  [[ "$val" == "on" ]] && emoji="$DEFAULT_ACK_EMOJI"
  python3 - "$ACCESS_FILE" "$emoji" <<'PY'
import json, sys
path, val = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
if val == "":
    data.pop("ackReaction", None)
else:
    data["ackReaction"] = val
with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write("\n")
PY
  chmod 600 "$ACCESS_FILE"
  if [[ "$val" == "on" ]]; then
    echo "ackReaction: $DEFAULT_ACK_EMOJI (takes effect on next message)"
  else
    echo "ackReaction: off"
  fi
}

# Idle-daemon eviction threshold, in minutes. 0 (or empty) disables it. Lives in
# $STATE_DIR/settings.json, which the poller live-reloads each poll loop — so a
# change applies within ~25s with no restart. With no value, prints the current
# setting. Mirrors _config_ack's JSON-merge so any other settings keys survive.
_config_idle_evict() {
  local val="${1:-}"
  # No value → print the current threshold (0 when unset/missing/corrupt).
  if [[ -z "$val" ]]; then
    if [[ -f "$SETTINGS_FILE" ]]; then
      python3 - "$SETTINGS_FILE" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    print(int(data.get("idle_evict_minutes", 0) or 0))
except Exception:
    print(0)
PY
    else
      echo 0
    fi
    return 0
  fi
  # Validate: a non-negative integer (0 disables).
  if [[ ! "$val" =~ ^[0-9]+$ ]]; then
    echo "Invalid value: $val (expected a non-negative integer of minutes; 0 disables)" >&2
    return 1
  fi
  mkdir -p "$STATE_DIR"
  chmod 700 "$STATE_DIR" 2>/dev/null || true
  python3 - "$SETTINGS_FILE" "$val" <<'PY'
import json, os, sys
path, val = sys.argv[1], int(sys.argv[2])
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f)
        if not isinstance(data, dict):
            data = {}
    except Exception:
        data = {}
data["version"] = 1
data["idle_evict_minutes"] = val
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
  chmod 600 "$SETTINGS_FILE"
  if [[ "$val" -eq 0 ]]; then
    echo "idle eviction: off"
  else
    echo "idle eviction: ${val} min (live — applies within ~25s, no restart)"
  fi
}

# Mid-turn auto-steer toggle. When ON (the default), a message sent during an
# in-flight turn debounces then gracefully interrupts the running turn so the
# batched messages flow into the next turn. OFF holds mid-turn messages until
# the turn ends (legacy behavior). Lives in $STATE_DIR/settings.json, which the
# poller live-reloads each poll loop — change applies within ~25s, no restart.
# With no value, prints the current setting (defaults to "on" when unset).
# Mirrors _config_idle_evict's JSON-merge so other settings keys survive.
_config_interrupt_steer() {
  local val="${1:-}"
  # No value → print the current setting ("on" unless explicitly disabled).
  if [[ -z "$val" ]]; then
    if [[ -f "$SETTINGS_FILE" ]]; then
      python3 - "$SETTINGS_FILE" <<'PY'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    print("on" if data.get("interrupt_on_message", True) else "off")
except Exception:
    print("on")
PY
    else
      echo on
    fi
    return 0
  fi
  case "$val" in
    on|off) ;;
    *)
      echo "Invalid value: $val (expected 'on' or 'off')" >&2
      return 1
      ;;
  esac
  mkdir -p "$STATE_DIR"
  chmod 700 "$STATE_DIR" 2>/dev/null || true
  python3 - "$SETTINGS_FILE" "$val" <<'PY'
import json, os, sys
path, val = sys.argv[1], sys.argv[2]
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f)
        if not isinstance(data, dict):
            data = {}
    except Exception:
        data = {}
data["version"] = 1
data["interrupt_on_message"] = (val == "on")
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY
  chmod 600 "$SETTINGS_FILE"
  if [[ "$val" == "on" ]]; then
    echo "mid-turn steering: on (live — applies within ~25s, no restart)"
  else
    echo "mid-turn steering: off (live — applies within ~25s, no restart)"
  fi
}

# Returns 0 if the CLI-managed caffeinate process is alive. PID file exists
# AND that PID is currently running — guards against stale pid files left by
# `kill -9`, OS reboots, etc.
_caffeinate_alive() {
  [[ -f "$CAFFEINATE_PID_FILE" ]] || return 1
  local pid
  pid=$(cat "$CAFFEINATE_PID_FILE" 2>/dev/null) || return 1
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

# Spawn `caffeinate -i` detached from this cta process so it survives the
# command exit. `-i` blocks idle system sleep but lets the display dim — same
# semantics as Pager's CaffeinateController. We don't mirror Pager's "AC-only"
# mode: that needs a power-state watcher running continuously and cta is
# one-shot. Users who want AC-conditional behavior should use Pager.
_caffeinate_start() {
  local bin="${CAFFEINATE_BIN:-/usr/bin/caffeinate}"
  mkdir -p "$(dirname "$CAFFEINATE_PID_FILE")"
  # Serialize the check-and-spawn across concurrent `cta config caffeinate on`
  # callers. Pager's CaffeinateController fires this from unserialized tasks on
  # every power-state change; without a lock two procs both pass
  # _caffeinate_alive before either writes the pid file, both spawn, and the
  # loser orphans (ppid 1) and leaks. Atomic `mkdir` is the lock; the bounded
  # wait keeps a crashed holder from wedging the caller forever (worst case:
  # caffeinate doesn't turn on this once — the next toggle retries).
  local lockdir="$CAFFEINATE_PID_FILE.lock" tries="${CAFFEINATE_LOCK_TRIES:-20}" i=0
  until mkdir "$lockdir" 2>/dev/null; do
    i=$((i + 1))
    if (( i >= tries )); then
      echo "Another caffeinate start is in progress; skipping."
      return 0
    fi
    sleep 0.1
  done
  if _caffeinate_alive; then
    rmdir "$lockdir" 2>/dev/null || true
    echo "Already running (pid $(cat "$CAFFEINATE_PID_FILE"))."
    return 0
  fi
  # nohup + & + disown: caffeinate keeps running after cta exits. setsid would
  # be cleaner but macOS doesn't ship it.
  nohup "$bin" -i >/dev/null 2>&1 &
  local pid=$!
  disown "$pid" 2>/dev/null || true
  echo "$pid" > "$CAFFEINATE_PID_FILE"
  rmdir "$lockdir" 2>/dev/null || true
  echo "Started caffeinate -i (pid $pid)."
}

_caffeinate_stop() {
  if ! _caffeinate_alive; then
    rm -f "$CAFFEINATE_PID_FILE"
    echo "Not running."
    return 0
  fi
  local pid
  pid=$(cat "$CAFFEINATE_PID_FILE")
  kill "$pid" 2>/dev/null || true
  rm -f "$CAFFEINATE_PID_FILE"
  echo "Stopped caffeinate (pid $pid)."
}

_config_caffeinate() {
  local val="${1:-}"
  case "$val" in
    on)  _caffeinate_start ;;
    off) _caffeinate_stop ;;
    "")
      echo "Usage: cta config caffeinate <on|off>" >&2
      return 1
      ;;
    *)
      echo "Invalid value: $val (expected 'on' or 'off')" >&2
      return 1
      ;;
  esac
}

# ─── Phase 3 pairing (one-time bootstrap secret) ────────────────────────────
# The bot is one-time-pairable via an 8-char code displayed at install time.
# In Telegram, the user sends `/pair XXXX-XXXX` to the bot — the poller claims
# this chat as MAIN_CHAT_ID and the sender as the allowlisted user, then
# consumes the code. After pairing, only the paired user can issue commands.
#
# Threat model: anyone who can see the pairing code can claim the bot before
# you do. Code lives at $STATE_DIR/pairing-code (mode 600, default $HOME/.pager)
# and is deleted on first successful pair. install.sh prints it once to stdout.
# Lost code → `cta pair-code --reset` regenerates.

# PAIRING_CODE_FILE moved to the top-of-file STATE_DIR block.

# Confusion-free alphabet: drops 0/O, 1/I/L, S/5, Z/2, B/8 — so a code copied
# from a terminal phone-photo is unambiguous. 25 chars × 8 ≈ 37 bits entropy,
# plenty for a one-time bootstrap secret that's gone in minutes.
_PAIRING_ALPHABET="ACDEFGHJKMNPQRTUVWXY34679"

_generate_pairing_code() {
  local bytes code="" abet="$_PAIRING_ALPHABET"
  # openssl rand is on every macOS; od -An -tu1 prints space-separated bytes
  bytes=$(openssl rand 16 2>/dev/null | od -An -tu1)
  for byte in $bytes; do
    [[ ${#code} -ge 8 ]] && break
    code="${code}${abet:$((byte % ${#abet})):1}"
  done
  printf '%s-%s\n' "${code:0:4}" "${code:4:8}"
}

# PAIRED_STATE_FILE moved to the top-of-file STATE_DIR block.

# cta pair — host-driven pairing. Bypasses Telegram entirely. The user types
# the chat_id (and optional user_id) they want to claim, and we write
# paired.json directly. Useful when:
#   - The inline-keyboard auto-pair flow doesn't fire (forum permission caches,
#     bot kicked before tap, etc.)
#   - The user wants deterministic setup over a magic flow
#   - Scripted / Pager-driven setup needs to skip the Telegram round-trip
# Discovery helper: `cta pair --auto` polls the Bot API for chats the bot
# has been seen in recently and prints them so the user can pick a chat_id
# without hunting through Telegram UI.
cmd_pair() {
  local sub="${1:-}"
  if [[ "$sub" == "--auto" ]]; then
    _pair_auto_discover
    return $?
  fi
  if [[ "$sub" == "--help" || -z "$sub" ]]; then
    cat <<EOF
Usage:
  cta pair <chat_id> [user_id]   Claim chat_id (negative for groups/supergroups).
                                 user_id defaults to the chat owner for DMs, or
                                 must be specified for groups (your Telegram user id).
  cta pair --auto                Scan recent Bot API updates for chats the bot
                                 has been added to and offer them to pick from.
EOF
    return 0
  fi
  local chat_id="$1"
  local user_id="${2:-}"
  if ! [[ "$chat_id" =~ ^-?[0-9]+$ ]]; then
    echo "cta pair: chat_id must be an integer (got '$chat_id')" >&2
    return 1
  fi
  if [[ -n "$user_id" ]] && ! [[ "$user_id" =~ ^[0-9]+$ ]]; then
    echo "cta pair: user_id must be a positive integer (got '$user_id')" >&2
    return 1
  fi
  # DM heuristic: positive chat_id = personal account, user_id == chat_id.
  # Groups/supergroups have negative chat_id; user_id is the operator's
  # personal Telegram user id (8-10 digits).
  if [[ -z "$user_id" ]]; then
    if [[ "$chat_id" =~ ^[0-9]+$ ]]; then
      user_id="$chat_id"
    else
      echo "cta pair: user_id is required for groups/supergroups (negative chat_id)." >&2
      echo "Hint: DM @userinfobot on Telegram to find your numeric user id." >&2
      return 1
    fi
  fi

  if [[ -f "$PAIRED_STATE_FILE" ]]; then
    local cur_chat
    cur_chat=$(jq -r '.chat_id' "$PAIRED_STATE_FILE" 2>/dev/null || echo "?")
    echo "Already paired with chat=$cur_chat. Run 'cta unpair' first to claim a new chat." >&2
    return 1
  fi

  mkdir -p "$(dirname "$PAIRED_STATE_FILE")"
  chmod 700 "$(dirname "$PAIRED_STATE_FILE")" 2>/dev/null || true
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  # umask 077 ensures the file lands at 0600 (it contains a chat_id that's
  # routable but not secret; still, defense in depth costs nothing).
  ( umask 077 && printf '{\n  "version": 1,\n  "chat_id": %s,\n  "user_id": %s,\n  "paired_at": "%s"\n}\n' \
      "$chat_id" "$user_id" "$now" > "$PAIRED_STATE_FILE" )
  echo "Paired: chat=$chat_id user=$user_id"

  # Recreate the wildcard mount if CLAUDE_CWD is set and no wildcard exists.
  # This mirrors the poller's ensureWildcardMount so host-driven pairs land
  # the user in a working state with one command.
  local cwd
  cwd=$(grep '^CLAUDE_CWD=' "$ENV_FILE" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
  if [[ -n "$cwd" && -d "$cwd" ]]; then
    if [[ -f "$MOUNT_STORE_TS" ]]; then
      local has_wildcard
      has_wildcard=$(bun run "$MOUNT_STORE_TS" list 2>/dev/null | jq -r '.mounts[] | select(.thread_id == "*") | .thread_id' 2>/dev/null)
      if [[ -z "$has_wildcard" ]]; then
        bun run "$MOUNT_STORE_TS" add '*' "$cwd" default >/dev/null 2>&1 \
          && echo "Wildcard mount auto-created: * → $cwd"
      fi
    fi
  fi
  echo "Tip: the poller picks up paired.json automatically (it watches mtime). No restart needed."
}

# Discover chats the bot has been added to by polling the Bot API for
# recent updates. Prints "<chat_id>  <title>" lines so the user can pick.
_pair_auto_discover() {
  local token
  token=$(grep '^TELEGRAM_BOT_TOKEN=' "$HOME/.claude/channels/telegram/.env" 2>/dev/null | cut -d= -f2- | tr -d '"')
  if [[ -z "$token" ]]; then
    echo "cta pair --auto: TELEGRAM_BOT_TOKEN not found in ~/.claude/channels/telegram/.env" >&2
    return 1
  fi
  # offset=-50 grabs the most recent 50 updates without consuming them
  # (Telegram only marks updates "read" when you ack a higher offset). The
  # live poller stays untouched.
  local resp
  resp=$(curl -fsS "https://api.telegram.org/bot${token}/getUpdates?offset=-50&timeout=0" 2>/dev/null)
  if [[ -z "$resp" ]] || ! echo "$resp" | jq -e '.ok' >/dev/null; then
    echo "cta pair --auto: getUpdates failed (network, token, or no recent updates)" >&2
    return 1
  fi
  echo "Recent chats the bot has seen (most-recent first):"
  echo "$resp" | jq -r '
    .result
    | map(.my_chat_member // .message // .callback_query.message // empty)
    | map({chat_id: .chat.id, title: (.chat.title // .chat.first_name // "<DM>"), type: .chat.type})
    | unique_by(.chat_id)
    | reverse
    | .[]
    | "  \(.chat_id)  [\(.type)]  \(.title)"
  '
  echo
  echo "To pair, run: cta pair <chat_id> <your_user_id>"
  echo "  (your_user_id is your numeric Telegram user id — DM @userinfobot to find it)"
}

cmd_unpair() {
  # Release the current paired chat so a new /pair (manual or auto via invite)
  # can claim a different one. Optional --keep-mounts leaves mounts.json
  # intact — useful if you're re-pairing to the same chat after testing
  # auto-pair (the mounts are still valid; only the chat_id/user_id changes).
  local keep_mounts=0
  if [[ "${1:-}" == "--keep-mounts" ]]; then keep_mounts=1; fi

  if [[ ! -f "$PAIRED_STATE_FILE" ]]; then
    echo "Not currently paired (paired.json absent)."
    return 0
  fi

  local chat_id user_id
  chat_id=$(jq -r '.chat_id' "$PAIRED_STATE_FILE" 2>/dev/null || echo "?")
  user_id=$(jq -r '.user_id' "$PAIRED_STATE_FILE" 2>/dev/null || echo "?")
  rm -f "$PAIRED_STATE_FILE"
  echo "Unpaired (was: chat=$chat_id user=$user_id)."

  if [[ "$keep_mounts" -eq 0 ]]; then
    # Wipe mounts under the mount-store lock so a concurrent `cta mount`
    # doesn't tear (previously this was `rm -f` which raced the lock).
    # Wildcard from install is regenerated next time install.sh runs.
    if [[ -f "$MOUNT_STORE_TS" ]]; then
      bun run "$MOUNT_STORE_TS" clear >/dev/null
      echo "Cleared mounts.json (use --keep-mounts to preserve next time)."
    fi
  fi

  echo "Next: re-add the bot in Telegram (auto-pair prompt fires), OR send /pair <code> using \`cta pair-code\`."
}

cmd_pair_code() {
  local mode="${1:---show}"
  case "$mode" in
    --init)
      # Create if missing. Idempotent — install.sh calls this on every run.
      if [[ -f "$PAIRING_CODE_FILE" ]]; then
        cat "$PAIRING_CODE_FILE"
        return 0
      fi
      mkdir -p "$(dirname "$PAIRING_CODE_FILE")"
      chmod 700 "$(dirname "$PAIRING_CODE_FILE")" 2>/dev/null || true
      ( umask 077 && _generate_pairing_code > "$PAIRING_CODE_FILE" )
      chmod 600 "$PAIRING_CODE_FILE"
      cat "$PAIRING_CODE_FILE"
      ;;
    --reset)
      # Force-regenerate. Used after lost code or to re-pair from scratch.
      mkdir -p "$(dirname "$PAIRING_CODE_FILE")"
      ( umask 077 && _generate_pairing_code > "$PAIRING_CODE_FILE" )
      chmod 600 "$PAIRING_CODE_FILE"
      cat "$PAIRING_CODE_FILE"
      ;;
    --show|"")
      if [[ -f "$PAIRING_CODE_FILE" ]]; then
        cat "$PAIRING_CODE_FILE"
      else
        echo "No pairing code present. Either pairing already completed, or run 'cta pair-code --reset'." >&2
        exit 1
      fi
      ;;
    *)
      echo "Usage: cta pair-code [--show | --init | --reset]" >&2
      exit 1
      ;;
  esac
}

# ─── Phase 2 mount management ───────────────────────────────────────────────
# `cta mount/umount/list` write to $STATE_DIR/mounts.json (~/.pager/...) via
# the mount-store TS lib (single source of truth for concurrency). Per-topic
# tmux sessions are spawned/killed inline so users don't need to run
# `cta start` again after a mount edit. The poller hot-reloads mounts.json
# on mtime change, so message routing follows automatically.

# Locate mount-store.ts. CTA_AGENT_DIR override lets tests point at the
# repo copy without installing.
_mount_store_path() {
  local d="${CTA_AGENT_DIR:-$INSTALL_DIR/agent}"
  echo "$d/mount-store/mount-store.ts"
}

_watch_render_path() {
  local d="${CTA_AGENT_DIR:-$INSTALL_DIR/agent}"
  echo "$d/poller/watch-render.ts"
}

cmd_mount() {
  local thread_id="${1:-}" path="${2:-}" label="${3:-}"
  if [[ -z "$thread_id" || -z "$path" ]]; then
    echo "Usage: cta mount <thread_id|dm> <path> [label]" >&2
    exit 1
  fi
  if [[ ! -d "$path" ]]; then
    echo "cta mount: '$path' is not a directory" >&2
    exit 1
  fi
  # Resolve to absolute path so the mount entry doesn't depend on $PWD.
  local abs_path
  abs_path=$(cd "$path" && pwd -P)

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta mount: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  # Provisional rows (helper-mode placeholders written by the poller's
  # spawnHelper path) must be atomically replaced, not added — addMount
  # throws on duplicate. Real (non-provisional) rows still refuse the
  # overwrite: cta mount is not a force command.
  local existing op="add"
  existing=$(bun run "$store" get "$thread_id" 2>/dev/null || echo "null")
  if [[ "$existing" != "null" ]] \
     && [[ "$(echo "$existing" | jq -r '.provisional // false')" == "true" ]]; then
    op="replace"
  fi

  local mount_json
  if [[ -n "$label" ]]; then
    mount_json=$(bun run "$store" "$op" "$thread_id" "$abs_path" "$label")
  else
    mount_json=$(bun run "$store" "$op" "$thread_id" "$abs_path")
  fi
  local rc=$?
  [[ "$rc" -ne 0 ]] && exit "$rc"

  # P6c: no per-topic process is spawned here. The poller hot-reloads
  # mounts.json on mtime change and lazy-spawns the ClaudeDaemon on the topic's
  # first inbound message.
  if _poller_alive; then
    echo "Mounted thread $thread_id at $abs_path (daemon spawns on next inbound)"
  else
    echo "Mounted thread $thread_id at $abs_path (will route on next 'cta start')"
  fi
}

cmd_umount() {
  local thread_id="${1:-}"
  if [[ -z "$thread_id" ]]; then
    echo "Usage: cta umount <thread_id|dm>" >&2
    exit 1
  fi

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta umount: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  local removed
  removed=$(bun run "$store" remove "$thread_id")
  local rc=$?
  [[ "$rc" -ne 0 ]] && exit "$rc"

  if [[ "$removed" == "null" ]]; then
    echo "cta umount: thread $thread_id was not mounted"
    return 0
  fi

  # P6c: nothing per-topic to tear down — removing the mounts.json row is
  # enough. The poller hot-reloads on mtime change and stops routing the thread
  # (its idle daemon, if any, is reaped by the registry / idle-evict).
  echo "Unmounted thread $thread_id"
}

# Look up topic display name from topics.json (poller-maintained cache of
# forum_topic_created / forum_topic_edited service messages). Returns empty
# if topics.json is missing, paired.json is missing, the thread_id is not
# numeric, or the topic wasn't observed by the poller (e.g., created before
# bot joined — Telegram has no getForumTopic API, so pre-bot topics are
# unrecoverable). Always exits 0 — callers treat empty as "unknown."
_topic_name() {
  local thread_id="$1"
  # "dm" mount in a group catches the General topic (Telegram omits
  # message_thread_id for General messages, so the poller routes them to
  # the "dm" fallback). Show "General" so the column matches what the user
  # sees in Telegram. In a private DM, "dm" stays unlabeled.
  if [[ "$thread_id" == "dm" ]]; then
    [[ -f "$PAIRED_STATE_FILE" ]] || return 0
    local chat_id
    chat_id=$(jq -r '.chat_id // empty' "$PAIRED_STATE_FILE" 2>/dev/null) || return 0
    [[ -n "$chat_id" && "$chat_id" -lt 0 ]] && echo "General"
    return 0
  fi
  # Non-numeric thread_ids ("*") have no forum topic by definition.
  [[ "$thread_id" =~ ^[0-9]+$ ]] || return 0
  [[ -f "$TOPICS_FILE" && -f "$PAIRED_STATE_FILE" ]] || return 0
  local chat_id
  chat_id=$(jq -r '.chat_id // empty' "$PAIRED_STATE_FILE" 2>/dev/null) || return 0
  [[ -n "$chat_id" ]] || return 0
  jq -r --arg key "${chat_id}/${thread_id}" \
    '.topics[$key].name // empty' "$TOPICS_FILE" 2>/dev/null
}

cmd_list() {
  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta list: mount-store not installed — rerun install.sh" >&2
    exit 1
  fi

  local raw
  raw=$(bun run "$store" list)

  if [[ "${1:-}" == "--json" ]]; then
    # Enrich each mount with topic_name when the poller has cached it.
    # Topic names live in a separate file (topics.json) maintained from
    # Telegram service messages; we join them here so JSON consumers
    # (Pager, scripts) get a one-stop view without a second roundtrip.
    local chat_id=""
    if [[ -f "$PAIRED_STATE_FILE" ]]; then
      chat_id=$(jq -r '.chat_id // empty' "$PAIRED_STATE_FILE" 2>/dev/null || echo "")
    fi
    local topics_arg="{}"
    if [[ -f "$TOPICS_FILE" ]]; then
      topics_arg=$(jq -c '.topics // {}' "$TOPICS_FILE" 2>/dev/null || echo "{}")
    fi
    # In a group (chat_id < 0), the "dm" mount catches the General topic;
    # surface "General" so JSON consumers don't have to re-derive this.
    local is_group="false"
    if [[ -n "$chat_id" && "$chat_id" -lt 0 ]]; then is_group="true"; fi
    echo "$raw" | jq \
      --arg chat_id "$chat_id" \
      --argjson topics "$topics_arg" \
      --argjson is_group "$is_group" \
      '.mounts |= map(
        . + (
          if (.thread_id | type) == "number" and ($chat_id | length) > 0 then
            { topic_name: ($topics[($chat_id + "/" + (.thread_id | tostring))].name // null) }
          elif .thread_id == "dm" and $is_group then
            { topic_name: "General" }
          else
            { topic_name: null }
          end
        )
      )'
    return
  fi

  local count
  count=$(echo "$raw" | jq '.mounts | length')
  if [[ "$count" -eq 0 ]]; then
    echo "No mounts. Add one with: cta mount <thread_id> <path>"
    return
  fi

  # P6c: per-topic daemons live inside the poller — there's no per-topic
  # process to probe, so the old TMUX + STATUS columns are gone. Overall
  # liveness is `cta status` (the single poller).
  printf "%-10s %-20s %-15s %s\n" "THREAD" "TOPIC" "LABEL" "PATH"
  while IFS=$'\t' read -r thread_id label path; do
    local topic
    topic=$(_topic_name "$thread_id")
    printf "%-10s %-20s %-15s %s\n" \
      "$thread_id" "${topic:--}" "${label:--}" "$path"
  done < <(echo "$raw" | jq -r '.mounts[] | [.thread_id, .label // "", .path] | @tsv')
}

# `cta watch <thread>` — print the current pane content of a topic's
# tmux session to stdout. Single-shot snapshot; the streaming variant
# is Phase B of the watch-live plan (see docs/plans/pager-watch-live.md).
#
# Used by Pager's WatchLive window (Phase A.2) and ad-hoc debugging.
# Pager is the primary client — keep the contract stable when iterating.
#
# Exit codes:
#   0  success — pane content printed to stdout.
#   1  no mount for thread, or usage/internal error.
#   2  mount exists but the tmux session is not alive.
cmd_watch() {
  local thread_id="" lines=200 keep_ansi=0 follow=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lines)
        if [[ -z "${2:-}" || ! "${2:-}" =~ ^[0-9]+$ ]]; then
          echo "cta watch: --lines requires a non-negative integer" >&2
          exit 1
        fi
        lines="$2"
        shift 2
        ;;
      --ansi)
        keep_ansi=1
        shift
        ;;
      --follow|-f)
        follow=1
        shift
        ;;
      --)
        shift
        thread_id="${1:-}"
        break
        ;;
      -*)
        echo "cta watch: unknown flag '$1'" >&2
        exit 1
        ;;
      *)
        if [[ -z "$thread_id" ]]; then
          thread_id="$1"
        else
          echo "cta watch: unexpected extra argument '$1'" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$thread_id" ]]; then
    echo "Usage: cta watch <thread_id|dm> [--lines N] [--ansi]" >&2
    exit 1
  fi

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta watch: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  # P6: Phase 4 daemons have no per-topic tmux pane to capture — render the
  # topic's conversation from its on-disk claude session JSONL instead.
  # watch-render does the mount + session-uuid + JSONL resolution and exits
  # 0 (ok) / 1 (no mount, bad args) / 2 (no transcript yet), matching the
  # contract Pager's WatchLive consumes. --ansi/--follow are inert (no ANSI in
  # JSONL; streaming dropped in P6 — one-shot snapshot).
  : "$keep_ansi" "$follow"
  local render
  render=$(_watch_render_path)
  if [[ ! -f "$render" ]]; then
    echo "cta watch: watch-render not installed at $render — rerun install.sh" >&2
    exit 1
  fi
  bun run "$render" "$thread_id" --lines "$lines"
}

# `cta send <thread> <text...>` — deliver text into a topic's claude daemon.
# Used by Pager's WatchLive input field (Phase C.2 of watch-live plan); also
# handy for scripted prompts.
#
# Phase 4 (daemon mode): topics are long-lived `claude -p` daemons whose stdin
# is owned by the poller, NOT tmux sessions — so the old tmux paste-buffer path
# is dead (it produced "tmux session is not alive"). Instead we drop a file into
# $STATE_DIR/inject/ which the poller watches and enqueues into the topic's
# daemon (lazy-spawning it if cold). Atomic write: `.tmp` then rename, so the
# poller never reads a partial file. Filename `<thread_id>__<nonce>.txt`.
#
# Exit codes:
#   0  queued for delivery (daemon may be cold — the poller spawns it)
#   1  no mount, usage error, or write failure
cmd_send() {
  local thread_id="${1:-}"
  shift 2>/dev/null || true
  local text="$*"

  if [[ -z "$thread_id" || -z "$text" ]]; then
    echo "Usage: cta send <thread_id|dm> <text...>" >&2
    exit 1
  fi

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta send: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  local mount_json
  mount_json=$(bun run "$store" get "$thread_id" 2>/dev/null || echo "null")
  if [[ -z "$mount_json" || "$mount_json" == "null" ]]; then
    echo "cta send: no mount for thread '$thread_id'" >&2
    exit 1
  fi

  # Drop an inject file the poller picks up (via fs.watch + loop-poll fallback).
  local inject_dir="$STATE_DIR/inject"
  if ! mkdir -p "$inject_dir" 2>/dev/null; then
    echo "cta send: cannot create inject dir $inject_dir" >&2
    exit 1
  fi
  chmod 700 "$inject_dir" 2>/dev/null || true

  local nonce tmp final
  nonce="$(date +%s)-${RANDOM}"
  tmp="$inject_dir/.${thread_id}__${nonce}.tmp"
  final="$inject_dir/${thread_id}__${nonce}.txt"

  if ! printf '%s' "$text" > "$tmp"; then
    rm -f "$tmp" 2>/dev/null || true
    echo "cta send: failed to write inject file" >&2
    exit 1
  fi
  # Atomic publish — the poller only reads `*.txt`, never the `.tmp`.
  if ! mv -f "$tmp" "$final"; then
    rm -f "$tmp" 2>/dev/null || true
    echo "cta send: failed to stage inject file" >&2
    exit 1
  fi
}

cmd_migrate_state() {
  # Move v0.1 state + install dirs to the v0.2 layout. Refuses to run while
  # the poller is alive — partial writes during migration would corrupt
  # mounts.json / paired.json. install.sh auto-invokes this on the first
  # upgrade after the rename; manual invocation is for operators with
  # custom layouts or interrupted migrations.
  # "Is the poller live against the dir we're about to move?" The heartbeat
  # file is touched every loop iter (~25s); if it's been updated in the last
  # 60s, something's writing to the legacy dir right now and the move would
  # corrupt state mid-write. Global pgrep would false-positive on a poller
  # that's already pointing at the new $STATE_DIR (e.g., partial migration).
  local hb="$LEGACY_STATE_DIR/heartbeat-poller"
  if [[ -f "$hb" ]]; then
    local hb_age=$(( $(date +%s) - $(stat -f %m "$hb" 2>/dev/null || echo 0) ))
    if [[ "$hb_age" -lt 60 ]]; then
      echo "cta migrate-state: poller is running against $LEGACY_STATE_DIR (heartbeat ${hb_age}s old)." >&2
      echo "Run 'cta stop' first, then re-run 'cta migrate-state'." >&2
      exit 1
    fi
  fi

  local did_state=0 did_install=0
  if [[ -d "$LEGACY_STATE_DIR" && ! -e "$STATE_DIR" ]]; then
    did_state=1
  elif [[ -d "$LEGACY_STATE_DIR" && -d "$STATE_DIR" ]]; then
    echo "cta migrate-state: both $LEGACY_STATE_DIR and $STATE_DIR exist." >&2
    echo "Merge or remove one side manually — refusing to clobber." >&2
    exit 1
  fi
  if [[ -d "$LEGACY_INSTALL_DIR" && ! -e "$INSTALL_DIR" ]]; then
    did_install=1
  elif [[ -d "$LEGACY_INSTALL_DIR" && -d "$INSTALL_DIR" ]]; then
    # Install dir is regenerated by install.sh, so a coexisting new dir is
    # almost certainly a fresh install on top of a legacy one. Safe to
    # delete the legacy install — the new one is authoritative.
    echo "cta migrate-state: legacy install dir present alongside new one; removing legacy."
    rm -rf "$LEGACY_INSTALL_DIR"
  fi

  if [[ $did_state == 0 && $did_install == 0 ]]; then
    echo "cta migrate-state: nothing to migrate."
    return 0
  fi

  # Backup manifest: a record of what moved, so a panicked operator can
  # locate files after the rename. Not a rollback script — `mv` is atomic
  # on the same filesystem (same $HOME volume), so rollback is `mv` back.
  local manifest
  manifest="$HOME/.pager-migration-$(date +%Y%m%d-%H%M%S).manifest"
  {
    echo "# pager-for-agents state migration"
    echo "# timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "# host: $(hostname)"
  } > "$manifest"

  if [[ $did_state == 1 ]]; then
    {
      echo ""
      echo "[state]"
      echo "from: $LEGACY_STATE_DIR"
      echo "to:   $STATE_DIR"
      echo "files:"
      find "$LEGACY_STATE_DIR" -type f -o -type l 2>/dev/null | sed 's|^|  |'
    } >> "$manifest"
    echo "moving state: $LEGACY_STATE_DIR → $STATE_DIR"
    # Parent must exist for mv-rename. Don't create the target dir itself
    # (mv would then place the legacy dir INSIDE the new dir).
    mkdir -p "$(dirname "$STATE_DIR")"
    if ! mv "$LEGACY_STATE_DIR" "$STATE_DIR"; then
      echo "cta migrate-state: state mv failed. Manifest at $manifest" >&2
      exit 1
    fi
  fi

  if [[ $did_install == 1 ]]; then
    {
      echo ""
      echo "[install]"
      echo "from: $LEGACY_INSTALL_DIR"
      echo "to:   $INSTALL_DIR"
    } >> "$manifest"
    echo "moving install: $LEGACY_INSTALL_DIR → $INSTALL_DIR"
    mkdir -p "$(dirname "$INSTALL_DIR")"
    if ! mv "$LEGACY_INSTALL_DIR" "$INSTALL_DIR"; then
      echo "cta migrate-state: install mv failed. Manifest at $manifest" >&2
      exit 1
    fi
  fi

  echo ""
  echo "✓ migration complete. Manifest: $manifest"
  echo "  Restart the agent: cta start"
}

# ─── cta init — first-run onboarding wizard ─────────────────────────────────
# Plan: project_onboarding_wizard_plan.md. Five steps, file-state-driven so
# re-running is idempotent — the wizard reads where you are from disk and
# resumes there. install.sh chains into `cta init` on fresh installs (when
# the plugin .env has no BOT_TOKEN yet).
#
# Step state predicates: each returns 0 (done) or 1 (pending). The Pager UI
# wizard reads the same files via _init_status output, so the two wizards
# stay in lock-step without a shared progress file.

_PLUGIN_ENV_FILE="$HOME/.claude/channels/telegram/.env"

# step 1: token line is present AND non-empty in the plugin .env.
# This is the "we have *a* token" predicate; getMe verify is separate.
_init_step1_token_ready() {
  [[ -f "$_PLUGIN_ENV_FILE" ]] || return 1
  local val
  val=$(grep '^TELEGRAM_BOT_TOKEN=' "$_PLUGIN_ENV_FILE" 2>/dev/null \
    | head -1 | cut -d= -f2- | tr -d '"' | tr -d '\r\n')
  [[ -n "$val" ]]
}

# step 2: no machine signal possible (Telegram /setprivacy is bot-side state
# we can't query). We always show the nudge, and the user confirms manually.
# For status reporting, we treat step 2 as "done" the moment step 1 is done —
# the user has been shown the nudge or has chosen to skip it.
_init_step2_privacy_acknowledged() {
  _init_step1_token_ready
}

# step 3: first inbound has been received. Two signals, either suffices:
#   - paired.json exists (means we already pulled past first inbound)
#   - agent.log has a daemon-dispatch line (means an inbound message routed)
_init_step3_inbound_seen() {
  [[ -f "$CTA_STATE_DIR/paired.json" ]] && return 0
  if [[ -f "$CTA_STATE_DIR/agent.log" ]]; then
    grep -q 'daemon\[' "$CTA_STATE_DIR/agent.log" 2>/dev/null && return 0
    # Fallback for pre-Phase-4 layouts: "update N → topic-" appears in
    # legacy log shapes. Match defensively so a partially-migrated install
    # still detects the milestone.
    grep -q 'update [0-9]\+ →' "$CTA_STATE_DIR/agent.log" 2>/dev/null && return 0
  fi
  return 1
}

# step 4: paired.json has both a chat_id and a non-empty user_id.
_init_step4_paired() {
  local f="$CTA_STATE_DIR/paired.json"
  [[ -f "$f" ]] || return 1
  local chat_id
  chat_id=$(jq -r '.chat_id // empty' "$f" 2>/dev/null)
  [[ -n "$chat_id" && "$chat_id" != "null" ]]
}

# step 5: a wildcard "*" mount exists. This is the "any new topic auto-mounts
# at $CLAUDE_CWD" default — the load-bearing UX guarantee that a fresh chat
# starts working without per-topic configuration.
_init_step5_default_mount() {
  local f="$CTA_STATE_DIR/mounts.json"
  [[ -f "$f" ]] || return 1
  local n
  n=$(jq '[.mounts[]? | select(.thread_id == "*")] | length' "$f" 2>/dev/null)
  [[ "${n:-0}" -gt 0 ]]
}

# Pre-flight bot token shape check. Telegram tokens are <numeric>:<35+ char
# base64-ish secret>. Catches obvious paste mistakes (no colon, truncated,
# pasted username instead) before we burn a getMe network call.
_init_validate_token_shape() {
  local t="${1:-}"
  [[ -n "$t" ]] || return 1
  [[ "$t" =~ ^[0-9]+:[A-Za-z0-9_-]{30,}$ ]]
}

# Hit Bot API getMe and return the bot's username on success. Caller uses
# the username for the "✓ paired to @yourbotname" status line. Times out at
# 8s so a wifi drop during onboarding doesn't hang the wizard forever.
_init_verify_bot_token() {
  local token="${1:-}"
  [[ -n "$token" ]] || return 1
  local response
  response=$(curl -sS --max-time 8 "https://api.telegram.org/bot${token}/getMe" 2>/dev/null) || return 1
  echo "$response" | jq -e '.ok == true' >/dev/null 2>&1 || return 1
  echo "$response" | jq -r '.result.username'
}

# Atomic write of the plugin .env. Mirrors install.sh's behavior: 0600 mode,
# tempfile + rename. Replaces the TELEGRAM_BOT_TOKEN line if present,
# appends otherwise. Other lines (CLAUDE_CWD, BOT_SESSION_ID, etc.) are
# preserved untouched so an init re-run doesn't wipe operator customizations.
_init_write_plugin_token() {
  local token="${1:-}"
  [[ -n "$token" ]] || return 1
  local dir
  dir=$(dirname "$_PLUGIN_ENV_FILE")
  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true
  local tmp="${_PLUGIN_ENV_FILE}.tmp.$$"
  ( umask 077
    if [[ -f "$_PLUGIN_ENV_FILE" ]]; then
      # grep -v exits nonzero when every line matches (every line stripped)
      # OR on read error — distinguish: count input lines first; if existing
      # file is non-empty but grep produced zero non-token lines, that's the
      # "all stripped" case (fine — empty preserve-set). Any other nonzero
      # exit means a read error; we MUST NOT replace the existing file with
      # a token-only file in that case (would destroy operator vars).
      local input_lines
      input_lines=$(wc -l < "$_PLUGIN_ENV_FILE" 2>/dev/null || echo 0)
      if grep -v '^TELEGRAM_BOT_TOKEN=' "$_PLUGIN_ENV_FILE" > "$tmp" 2>/dev/null; then
        : # grep ok (found non-token lines, wrote them)
      else
        local rc=$?
        # rc=1 → no non-token lines (file was just the token line). Empty tmp
        # is the correct preserve-set; proceed. rc>=2 → real error.
        if [[ "$rc" -ne 1 ]]; then
          rm -f "$tmp"
          return 2
        fi
      fi
      # Sanity: tmp must exist; if the original had non-token content, tmp
      # must be non-empty too. Belt-and-suspenders against partial writes.
      if [[ ! -f "$tmp" ]]; then
        return 2
      fi
      if [[ "$input_lines" -gt 1 ]] && [[ ! -s "$tmp" ]]; then
        # Original had multiple lines but tmp is empty — something stripped
        # too much. Refuse the destructive overwrite.
        rm -f "$tmp"
        return 2
      fi
    else
      : > "$tmp"
    fi
    printf 'TELEGRAM_BOT_TOKEN=%s\n' "$token" >> "$tmp"
  )
  chmod 600 "$tmp"
  mv -f "$tmp" "$_PLUGIN_ENV_FILE"
}

# Machine-readable wizard status. One line per step:
#   step <N> <done|pending> <human-readable label>
# Used by `cta init` for the resume banner and by the Pager wizard's IPC.
_init_status() {
  local step_done
  for step in 1 2 3 4 5; do
    case "$step" in
      1) "_init_step1_token_ready"           && step_done="done" || step_done="pending"
         echo "step 1 $step_done token (Bot API getMe verified)" ;;
      2) "_init_step2_privacy_acknowledged"  && step_done="done" || step_done="pending"
         echo "step 2 $step_done /setprivacy disabled in @BotFather (group-mode visibility)" ;;
      3) "_init_step3_inbound_seen"          && step_done="done" || step_done="pending"
         echo "step 3 $step_done first inbound (a message reached the bot)" ;;
      4) "_init_step4_paired"                && step_done="done" || step_done="pending"
         echo "step 4 $step_done paired chat (only your chat can talk to the bot)" ;;
      5) "_init_step5_default_mount"         && step_done="done" || step_done="pending"
         echo "step 5 $step_done default mount (\"*\" wildcard set to your project dir)" ;;
    esac
  done
}

# Wait up to N seconds for the first inbound, polling agent.log + paired.json.
# Returns 0 on detection, 1 on timeout. Prints animated dots so the user
# doesn't think the wizard is dead.
_init_wait_for_inbound() {
  local timeout="${1:-300}"
  local deadline=$(( $(date +%s) + timeout ))
  local frame=0
  while [[ $(date +%s) -lt $deadline ]]; do
    if _init_step3_inbound_seen; then
      printf "\r✓ Inbound received.                              \n"
      return 0
    fi
    frame=$(( (frame + 1) % 4 ))
    local dots
    case $frame in
      0) dots="   " ;;
      1) dots=".  " ;;
      2) dots=".. " ;;
      3) dots="..." ;;
    esac
    printf "\r  waiting for first message%s " "$dots"
    sleep 1
  done
  printf "\r  ⚠ no inbound after %ds — abandoning wait.            \n" "$timeout"
  return 1
}

# Wait up to N seconds for paired.json mtime change (or initial appearance).
_init_wait_for_pair() {
  local timeout="${1:-120}"
  local deadline=$(( $(date +%s) + timeout ))
  local f="$CTA_STATE_DIR/paired.json"
  local start_mtime=0
  [[ -f "$f" ]] && start_mtime=$(stat -f %m "$f" 2>/dev/null || echo 0)
  local frame=0
  while [[ $(date +%s) -lt $deadline ]]; do
    if [[ -f "$f" ]]; then
      local cur_mtime
      cur_mtime=$(stat -f %m "$f" 2>/dev/null || echo 0)
      if [[ "$cur_mtime" -ne "$start_mtime" ]] && _init_step4_paired; then
        printf "\r✓ Pairing complete.                                  \n"
        return 0
      fi
    fi
    frame=$(( (frame + 1) % 4 ))
    local dots
    case $frame in
      0) dots="   " ;;
      1) dots=".  " ;;
      2) dots=".. " ;;
      3) dots="..." ;;
    esac
    printf "\r  waiting for /pair from your chat%s " "$dots"
    sleep 1
  done
  printf "\r  ⚠ no pair after %ds — try 'cta pair <chat_id>' manually.   \n" "$timeout"
  return 1
}

# ─── cta open <thread> — β handoff: TUI takeover for a daemon-mode topic ────
# Tells the poller to release the topic's daemon (SIGTERM → clean session
# lock release), then execs `claude --resume <uuid>` in the topic's project
# directory. When the user exits the TUI, signals the poller to lazy-spawn
# the daemon again on the next inbound message.
#
# The IPC is via flag files in $STATE_DIR/release-flags/:
#   <thread>      written here = "please release this topic"
#   <thread>.ack  written by poller = "released, you can take over"
# Reacquire = delete the .ack file. Poller polls every loop tick.
cmd_open() {
  local thread_id="${1:-}"
  if [[ -z "$thread_id" ]]; then
    echo "Usage: cta open <thread_id|dm>" >&2
    exit 1
  fi

  # Find the mount so we know the project_path. cta-side resolution mirrors
  # what the poller does — no IPC needed for read-only info.
  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta open: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi
  local mount_json
  mount_json=$(bun run "$store" get "$thread_id" 2>/dev/null || echo "null")
  if [[ -z "$mount_json" || "$mount_json" == "null" ]]; then
    echo "cta open: no mount for thread '$thread_id'" >&2
    exit 1
  fi
  local project_path
  project_path=$(echo "$mount_json" | jq -r '.path')
  if [[ ! -d "$project_path" ]]; then
    echo "cta open: project_path '$project_path' is not a directory (stale mount?)" >&2
    exit 1
  fi

  # Find the session UUID at $STATE_DIR/sessions/<thread_id>. If it doesn't
  # exist the topic has never had a turn — nothing to resume; offer to start
  # a fresh session-id instead.
  local sess_file="$STATE_DIR/sessions/$thread_id"
  local uuid=""
  if [[ -f "$sess_file" ]]; then
    uuid=$(cat "$sess_file" 2>/dev/null | tr -d '[:space:]')
  fi

  # Signal the poller to release the daemon. Touch the flag file, then poll
  # for the .ack rename. 8s ceiling matches the poller's main-loop tick
  # cadence (long-poll ~25s but processReleaseFlags runs every iteration).
  local flag_dir="$STATE_DIR/release-flags"
  mkdir -p "$flag_dir"
  chmod 700 "$flag_dir" 2>/dev/null || true
  local flag="$flag_dir/$thread_id"
  local ack="$flag.ack"
  # Clean any stale ack from a previous open that crashed before reacquire.
  rm -f "$ack" 2>/dev/null || true
  touch "$flag"

  echo "Requesting daemon release for thread $thread_id…"
  local waited=0
  while [[ "$waited" -lt 800 ]]; do  # 80s ceiling — Telegram long-poll can hold 25s
    if [[ -f "$ack" ]]; then break; fi
    sleep 0.1
    waited=$((waited + 1))
  done
  if [[ ! -f "$ack" ]]; then
    echo "cta open: poller didn't acknowledge release within 80s." >&2
    echo "Is the poller running? Check 'cta status' / tail $STATE_DIR/agent.log." >&2
    rm -f "$flag" 2>/dev/null || true
    exit 1
  fi
  echo "Daemon released. Launching claude TUI in $project_path…"

  # Trap so we reacquire even if the user kills the terminal mid-session.
  trap 'rm -f "'"$ack"'" 2>/dev/null; echo; echo "Daemon will respawn lazily on next Telegram message."' EXIT INT TERM

  # cd + exec claude. --resume picks up the existing JSONL transcript so
  # the user lands mid-conversation. If uuid is empty (never had a turn),
  # claude opens a fresh session in the project dir.
  cd "$project_path" || { echo "cta open: cd to $project_path failed" >&2; exit 1; }
  if [[ -n "$uuid" ]]; then
    claude --resume "$uuid" || true
  else
    claude || true
  fi
  # Trap runs the reacquire (rm -f "$ack") automatically.
}

cmd_init() {
  # Hard requirements: bash, jq, curl. All are macOS-stock or already
  # installed by the time `cta` runs (bash is the interpreter).
  if ! command -v jq >/dev/null || ! command -v curl >/dev/null; then
    echo "cta init: jq and curl are required (Homebrew: brew install jq curl)" >&2
    exit 1
  fi

  echo
  echo "── pager-for-agents setup ──"
  echo
  _init_status | sed 's/^/  /'
  echo

  # ─── Step 1: bot token ────────────────────────────────────────────────────
  if _init_step1_token_ready; then
    local existing
    existing=$(grep '^TELEGRAM_BOT_TOKEN=' "$_PLUGIN_ENV_FILE" 2>/dev/null \
      | head -1 | cut -d= -f2- | tr -d '"' | tr -d '\r\n')
    local username
    if username=$(_init_verify_bot_token "$existing"); then
      echo "Step 1/5 ✓ token already saved (verified @${username})"
      printf "Keep this bot or replace? [k/r] "
      read -r choice
      if [[ "$choice" == "r" || "$choice" == "R" ]]; then
        _init_prompt_token
      fi
    else
      echo "Step 1/5 ⚠ existing token failed getMe — re-prompt."
      _init_prompt_token
    fi
  else
    echo "Step 1/5  bot token"
    echo "  Open Telegram → @BotFather → /newbot → follow prompts → copy the token."
    _init_prompt_token
  fi

  # ─── Step 2: /setprivacy ──────────────────────────────────────────────────
  echo
  echo "Step 2/5  group-mode visibility (/setprivacy)"
  echo "  In @BotFather: /setprivacy → select your bot → Disable."
  echo "  Without this, the bot can't see non-command messages in groups."
  printf "Press Enter when done (or 'skip' to continue): "
  # -t 600: 10-min ceiling. Without it, the wizard hangs forever if invoked
  # over an SSH connection that drops, or from a CI/CD pipeline that closes
  # stdin without sending EOF. Exit code 142 (timeout) is benign — we just
  # continue to the next step.
  read -t 600 -r _ || true

  # ─── Step 3: first inbound ────────────────────────────────────────────────
  echo
  echo "Step 3/5  first inbound message"
  if ! _poller_alive; then
    echo "  starting the poller…"
    if ! cmd_start >/dev/null 2>&1; then
      echo "  ⚠ poller failed to start. Run 'cta start' manually and check logs:" >&2
      echo "     tail -f $CTA_STATE_DIR/agent.log" >&2
      echo "     Skipping the inbound-wait step." >&2
      return 1
    fi
    sleep 3
    # Verify the poller actually came up — cmd_start can succeed superficially
    # (launchctl loaded) while bun never bound. Without this check the wizard
    # spins for 5 minutes on _init_wait_for_inbound watching nothing happen.
    if ! _poller_alive; then
      echo "  ⚠ poller didn't come up after cmd_start. Likely causes:" >&2
      echo "     - missing TELEGRAM_BOT_TOKEN in ~/.claude/channels/telegram/.env" >&2
      echo "     - bun not on PATH" >&2
      echo "     - $CTA_INSTALL_DIR/agent/poller/poller.ts missing (rerun install.sh)" >&2
      echo "     Check $CTA_STATE_DIR/agent.log and rerun 'cta init' to retry." >&2
      return 1
    fi
  fi
  if _init_step3_inbound_seen; then
    echo "  ✓ already seen — skipping."
  else
    echo "  Send any message to your bot from your chat. (Group? Add the bot first.)"
    _init_wait_for_inbound 300 || true
  fi

  # ─── Step 4: pair ─────────────────────────────────────────────────────────
  echo
  echo "Step 4/5  pair a chat (locks the bot to one chat + user)"
  if _init_step4_paired; then
    echo "  ✓ already paired — skipping. (Use 'cta unpair' to re-pair.)"
  else
    local code
    code=$(cmd_pair_code --init 2>/dev/null || cmd_pair_code 2>/dev/null || true)
    if [[ -n "$code" ]]; then
      echo "  In your chat, send:  /pair $code"
      echo "  Or run 'cta pair --auto' from another terminal to pick a chat by id."
      _init_wait_for_pair 180 || true
    else
      echo "  ⚠ couldn't generate a pairing code. Run 'cta pair-code --reset' manually."
    fi
  fi

  # ─── Step 5: default mount ────────────────────────────────────────────────
  echo
  echo "Step 5/5  default project directory"
  if _init_step5_default_mount; then
    local cur
    cur=$(jq -r '[.mounts[]? | select(.thread_id == "*")][0].path' \
      "$CTA_STATE_DIR/mounts.json" 2>/dev/null)
    echo "  ✓ already set: $cur"
  else
    local default_cwd
    default_cwd=$(grep '^CLAUDE_CWD=' "$CTA_STATE_DIR/.env" 2>/dev/null \
      | head -1 | cut -d= -f2- | tr -d '"' || true)
    [[ -z "$default_cwd" ]] && default_cwd="$HOME/claude-home"
    printf "  Path for new topics [%s]: " "$default_cwd"
    read -r path
    path="${path:-$default_cwd}"
    # Expand ~ before we test for directoryhood — the user is going to type
    # ~/projects, not /Users/x/projects, and bash doesn't expand it inside
    # a read-into variable.
    path="${path/#\~/$HOME}"
    if [[ ! -d "$path" ]]; then
      printf "  '%s' doesn't exist — create it? [Y/n] " "$path"
      read -r mk
      if [[ "$mk" != "n" && "$mk" != "N" ]]; then
        mkdir -p "$path" || { echo "  ⚠ mkdir failed — skipping default mount."; }
      fi
    fi
    if [[ -d "$path" ]]; then
      cmd_mount '*' "$path" default >/dev/null && echo "  ✓ default mount set"
    fi
  fi

  # ─── Done ─────────────────────────────────────────────────────────────────
  echo
  echo "── setup complete ──"
  _init_status | sed 's/^/  /'
  echo
  echo "  Try sending another message to your bot — it should reply now."
  echo "  Re-run anytime with 'cta init' (it resumes where you left off)."
}

# Prompt for a bot token interactively. Reads with -s so terminal history /
# screen recording doesn't capture it. Validates shape locally first, then
# hits getMe for live verification before persisting.
_init_prompt_token() {
  while true; do
    printf "  Paste the bot token (hidden): "
    local token
    read -rs token
    echo
    if [[ -z "$token" ]]; then
      echo "  ⚠ empty — try again, or Ctrl-C to abort."
      continue
    fi
    if ! _init_validate_token_shape "$token"; then
      echo "  ⚠ doesn't look like a Telegram bot token (expected '<digits>:<chars>')."
      continue
    fi
    local username
    if username=$(_init_verify_bot_token "$token"); then
      _init_write_plugin_token "$token"
      echo "  ✓ verified — @${username}"
      return 0
    else
      echo "  ⚠ getMe rejected this token. Check it in @BotFather and try again."
    fi
  done
}

cmd_help() {
  cat <<EOF
cta — claude-telegram-agent CLI

Usage:
  cta status [--json]             Show agent health (text by default, JSON for tooling)
  cta start                       Load the LaunchAgents (poller + watchdog)
  cta stop                        Boot out the LaunchAgents (poller + watchdog)
  cta mount <thread> <path>       Mount a project dir at a Telegram thread (or "dm")
  cta umount <thread>             Unmount a thread (stops routing it)
  cta list [--json]               List current mounts
  cta watch <thread> [--lines N] [--ansi]
                                  Print the topic's recent session transcript
  cta send <thread> <text...>     Deliver text into a topic's claude daemon (Pager watch-live input)
  cta pair-code [--init|--reset]  Show / generate the one-time Telegram pairing code
  cta pair <chat_id> [user_id]    Host-driven pairing (skip the Telegram round-trip)
  cta pair --auto                 Show chats the bot has been seen in recently
  cta unpair [--keep-mounts]      Release the paired chat so you can pair a different one
  cta config ack <on|off>         Toggle the bot's per-message ack reaction
  cta config caffeinate <on|off>  Toggle caffeinate -i (keep Mac awake)
  cta config interrupt-steer <on|off>  Toggle mid-turn steering (interrupt a running turn)
  cta migrate-state               Move v0.1 ~/.claude-telegram-agent/ → ~/.pager/
  cta init                        First-run setup wizard (token → pair → default mount)
  cta open <thread>               Open a TUI for a topic (β handoff — daemon yields, claude --resume)
  cta help                        This message

Reads ~/.pager/.env (CTA_STATE_DIR-overridable) for configurable settings.

Pager and any other UI should call \`cta status --json\` rather than greping
\`ps\` / \`launchctl list\` directly. Schema is versioned; see the header of
this script for the contract.
EOF
}

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true
  case "$cmd" in
    status)
      if [[ "${1:-}" == "--json" ]]; then
        cmd_status json
      else
        cmd_status text
      fi
      ;;
    start) cmd_start ;;
    stop)  cmd_stop ;;
    mount) cmd_mount "$@" ;;
    umount) cmd_umount "$@" ;;
    list)  cmd_list "$@" ;;
    watch) cmd_watch "$@" ;;
    send) cmd_send "$@" ;;
    pair-code) cmd_pair_code "$@" ;;
    pair) cmd_pair "$@" ;;
    unpair) cmd_unpair "$@" ;;
    config) cmd_config "$@" ;;
    migrate-state) cmd_migrate_state "$@" ;;
    init) cmd_init "$@" ;;
    open) cmd_open "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      echo "Unknown command: $cmd" >&2
      cmd_help >&2
      exit 1
      ;;
  esac
}

# Only run main when executed directly. Sourcing exposes _json_* helpers and
# command functions for the test suite without invoking anything.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
