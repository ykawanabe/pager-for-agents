#!/bin/bash
# cta — claude-telegram-agent CLI.
#
# The single source of truth for "what is the agent doing right now?" and
# "start / stop the agent". Pager and any future UI call this instead of
# re-implementing process detection. As long as the JSON schema below stays
# backward-compatible, agent-side changes (rename a tmux session, switch
# plugin runtime, move a file) don't break the UI.
#
# Schema (cta status --json):
#   {
#     "schema_version": 1,
#     "launch_agent": {"label": "com.claude-agent", "loaded": true|false},
#     "claude":       {"pid": <int>|null, "rss_mb": <int>|null},
#     "telegram_mcp": {"alive": true|false},
#     "tmux": {
#       "claude":   {"name": "<session>", "alive": true|false},
#       "watchdog": {"name": "<session>", "alive": true|false}
#     },
#     "last_activity": "<ISO8601>" | null
#   }
#
# Bumps to schema_version are reserved for breaking changes (F1+F2 multi-topic
# will introduce schema_version=2 with a per-topic array). Additive fields
# stay at the current version.
set -uo pipefail

# When invoked from a launchd-spawned process (Claude Pager via CTAClient,
# or the LaunchAgent's own restart cycle), $PATH is stripped to the macOS
# default: /usr/bin:/bin:/usr/sbin:/sbin. tmux lives in /opt/homebrew/bin
# (Apple Silicon) or /usr/local/bin (Intel) — neither is in the stripped
# PATH. Without this prepend, `tmux has-session` silently fails with
# "command not found" and cta reports tmux=false even when both sessions
# are healthy. Prepend rather than overwrite so any caller-set PATH still
# wins for entries we don't list.
export PATH="$HOME/.bun/bin:/opt/homebrew/bin:/usr/local/bin:${PATH:-/usr/bin:/bin}:$HOME/.local/bin"

PLIST_LABEL="com.claude-agent"
PLIST_PATH="$HOME/Library/LaunchAgents/${PLIST_LABEL}.plist"
BOT_PID_FILE="$HOME/.claude/channels/telegram/bot.pid"
ACCESS_FILE="$HOME/.claude/channels/telegram/access.json"
START_SCRIPT="$HOME/.local/bin/start_agents.sh"

# State + install dirs. Defaults match agent/lib/paths.ts. Env overrides
# (CTA_STATE_DIR / CTA_INSTALL_DIR) flow through here so a single shell can
# point both the CLI and the agent at the same custom location.
STATE_DIR="${CTA_STATE_DIR:-$HOME/.pager}"
INSTALL_DIR="${CTA_INSTALL_DIR:-$HOME/.local/share/pager}"
LEGACY_STATE_DIR="$HOME/.claude-telegram-agent"
LEGACY_INSTALL_DIR="$HOME/.local/share/claude-telegram-agent"

# All state-file paths MUST derive from $STATE_DIR. Hardcoding $HOME/.claude-telegram-agent/...
# anywhere outside cmd_migrate_state diverges from agent/lib/paths.ts (which uses
# stateDir() = ~/.pager) and causes silent mismatches — e.g., poller writes to ~/.pager,
# cta reads from the legacy dir, /pair fails with "Pairing code did not match".
# Regression test in tests/test_cta.sh guards this.
ENV_FILE="$STATE_DIR/.env"
CAFFEINATE_PID_FILE="$STATE_DIR/caffeinate.pid"
PAIRING_CODE_FILE="$STATE_DIR/pairing-code"
PAIRED_STATE_FILE="$STATE_DIR/paired.json"
MOUNTS_FILE="$STATE_DIR/mounts.json"
TOPICS_FILE="$STATE_DIR/topics.json"
MOUNT_STORE_TS="$INSTALL_DIR/agent/mount-store/mount-store.ts"

# Default emoji used by `cta config ack on`. Must be in Telegram's free-bot
# reaction whitelist — eyes reads as "seen" and is universally available.
# Kept in sync with Pager's kDefaultAckEmoji (SettingsView.swift) so the two
# UIs agree on what "on" means.
DEFAULT_ACK_EMOJI="👀"

# Load .env early so configurable session names take effect. Falls back to
# defaults if .env doesn't exist yet (e.g., before install.sh has run).
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck source=/dev/null
  source "$ENV_FILE"
  set +a
fi
TMUX_SESSION_CLAUDE="${TMUX_SESSION_CLAUDE:-claude}"
TMUX_SESSION_WATCHDOG="${TMUX_SESSION_WATCHDOG:-watchdog}"

# MULTI_TOPIC mode replaces the v0 `claude` tmux session with `poller` + N
# `topic-<thread_id>` sessions. Status checks delegate to those instead so
# Pager doesn't keep reporting "claude=✗" forever.
_multi_topic_enabled() {
  [[ "${MULTI_TOPIC:-0}" == "1" ]]
}

# ─── helpers ─────────────────────────────────────────────────────────────────

# Atomic single-arg form. The piped `launchctl list | grep -q LABEL` shape
# under `set -uo pipefail` flips false ~8% of polls under I/O load: grep -q
# closes its stdin on first match, launchctl is still streaming over IPC,
# gets SIGPIPE, pipeline returns non-zero, Pager sees a false Degraded.
_la_loaded() {
  launchctl list "$PLIST_LABEL" >/dev/null 2>&1
}

# Print "<pid> <rss_kb>" if claude is running, else empty line. Caller parses.
# MULTI_TOPIC: any `claude --mcp-config` spawned by topic-wrapper.sh counts as
# "claude alive" — there's no single canonical `claude --channels` process to
# look for. Single-topic v0 keeps the old --channels grep.
_claude_ps_line() {
  local pat
  if _multi_topic_enabled; then pat="claude --mcp-config"
  else pat="claude --channels plugin:telegram"
  fi
  # Local `set +o pipefail`: the head -1 / grep chain can SIGPIPE the upstream
  # ps under load and flip pipefail to non-zero, which would empty out the
  # claude.pid field in cta status. Same family of bug as _la_loaded's old form.
  # shellcheck disable=SC2009  # pgrep can't match multi-word patterns + we need rss
  ( set +o pipefail
    ps -Ao pid=,rss=,command= 2>/dev/null \
      | grep "$pat" \
      | grep -v grep \
      | head -1 \
      | awk '{print $1, $2}'
  )
}

# MULTI_TOPIC: per-topic mcp-telegram process lives at .../agent/mcp-telegram/server.ts.
# v0: the official plugin's bun server is also a server.ts; same grep matches both.
# pgrep -f is atomic — no pipe, no pipefail-vs-SIGPIPE race window.
#
# Liveness-check vs kill-target distinction: this generic `bun.*server.ts`
# match is intentional for "is _any_ MCP server alive?". A false-positive
# (user runs their own unrelated bun + server.ts) is acceptable here. cmd_stop
# uses a plugin-specific pattern instead, so we never kill the user's other
# bun processes (see test_cta.sh "cmd_stop: did NOT pgrep for plugin-specific
# pattern" regression test).
_mcp_alive() {
  pgrep -f "bun.*server.ts" >/dev/null 2>&1
}

_tmux_session_alive() {
  tmux has-session -t "$1" 2>/dev/null
}

# Returns ISO8601 mtime of bot.pid, or empty if missing.
_last_activity() {
  [[ -f "$BOT_PID_FILE" ]] || return 0
  # macOS stat differs from GNU; use BSD flags.
  TZ=UTC stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' "$BOT_PID_FILE" 2>/dev/null || true
}

# Emit a JSON literal for an integer-or-null. Empty input → "null", else the
# integer itself. No quoting (JSON numbers are bare).
_json_int_or_null() {
  if [[ -z "$1" ]]; then
    printf 'null'
  else
    printf '%s' "$1"
  fi
}

# Emit a JSON literal for a string-or-null. Empty → "null", else "<escaped>".
# Escapes the two characters that can break a JSON string literal in practice
# here: backslash and double-quote. Newlines and control chars don't appear
# in any of our sources (process names, label strings, ISO dates).
_json_str_or_null() {
  if [[ -z "$1" ]]; then
    printf 'null'
  else
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    printf '"%s"' "$s"
  fi
}

_json_bool() {
  if "$@"; then printf 'true'; else printf 'false'; fi
}

# ─── commands ────────────────────────────────────────────────────────────────

cmd_status() {
  local format="${1:-text}"

  local la_loaded
  if _la_loaded; then la_loaded=true; else la_loaded=false; fi

  local ps_line pid="" rss_kb=""
  ps_line=$(_claude_ps_line)
  if [[ -n "$ps_line" ]]; then
    pid="${ps_line%% *}"
    rss_kb="${ps_line##* }"
  fi

  local mcp_alive
  if _mcp_alive; then mcp_alive=true; else mcp_alive=false; fi

  # In MULTI_TOPIC mode, `claude` (the v0 control session) doesn't exist —
  # `poller` plays that role. Map the JSON's `tmux.claude.alive` field to the
  # poller's status so existing consumers (Pager) keep working unchanged.
  local control_session
  if _multi_topic_enabled; then control_session="poller"
  else control_session="$TMUX_SESSION_CLAUDE"
  fi
  local tmux_claude tmux_watchdog
  if _tmux_session_alive "$control_session"; then tmux_claude=true; else tmux_claude=false; fi
  if _tmux_session_alive "$TMUX_SESSION_WATCHDOG"; then tmux_watchdog=true; else tmux_watchdog=false; fi

  local activity
  activity=$(_last_activity)

  local caffeinate_pid="" caffeinate_alive
  if _caffeinate_alive; then
    caffeinate_alive=true
    caffeinate_pid=$(cat "$CAFFEINATE_PID_FILE" 2>/dev/null)
  else
    caffeinate_alive=false
  fi

  if [[ "$format" == "json" ]]; then
    local rss_mb=""
    [[ -n "$rss_kb" ]] && rss_mb=$(( rss_kb / 1024 ))
    cat <<EOF
{
  "schema_version": 1,
  "launch_agent": {"label": $(_json_str_or_null "$PLIST_LABEL"), "loaded": $la_loaded},
  "claude": {"pid": $(_json_int_or_null "$pid"), "rss_mb": $(_json_int_or_null "$rss_mb")},
  "telegram_mcp": {"alive": $mcp_alive},
  "tmux": {
    "claude": {"name": $(_json_str_or_null "$control_session"), "alive": $tmux_claude},
    "watchdog": {"name": $(_json_str_or_null "$TMUX_SESSION_WATCHDOG"), "alive": $tmux_watchdog}
  },
  "caffeinate": {"alive": $caffeinate_alive, "pid": $(_json_int_or_null "$caffeinate_pid")},
  "last_activity": $(_json_str_or_null "$activity")
}
EOF
  else
    printf 'LaunchAgent (%s): %s\n' "$PLIST_LABEL" "$la_loaded"
    printf 'claude PID:       %s\n' "${pid:-(none)}"
    if [[ -n "$rss_kb" ]]; then
      printf 'claude RSS:       %s MB\n' "$(( rss_kb / 1024 ))"
    fi
    printf 'Telegram MCP:     %s\n' "$mcp_alive"
    printf 'tmux %s:%s   %s\n' "$TMUX_SESSION_CLAUDE" \
      "$(printf '%*s' $((10 - ${#TMUX_SESSION_CLAUDE})) '')" "$tmux_claude"
    printf 'tmux %s:%s %s\n' "$TMUX_SESSION_WATCHDOG" \
      "$(printf '%*s' $((10 - ${#TMUX_SESSION_WATCHDOG})) '')" "$tmux_watchdog"
    if [[ "$caffeinate_alive" == "true" ]]; then
      printf 'Caffeinate:       %s (pid %s)\n' "$caffeinate_alive" "$caffeinate_pid"
    else
      printf 'Caffeinate:       %s\n' "$caffeinate_alive"
    fi
    printf 'Last activity:    %s\n' "${activity:-(none)}"
  fi
}

cmd_start() {
  # Idempotent. If both sessions are already alive, do nothing — no destructive
  # respawn, no claude PID churn, no conversation drop. start_agents.sh kills
  # existing sessions before spawning new ones (intentional for a fresh boot
  # or recovery), so it must NOT be the path for "make sure the bot is up."
  # Pager calls this on every launch via ensureBotRunning(); without this
  # guard, every Pager launch took the bot offline for ~3s.
  if _tmux_session_alive "$TMUX_SESSION_CLAUDE" && _tmux_session_alive "$TMUX_SESSION_WATCHDOG"; then
    echo "Already running (tmux $TMUX_SESSION_CLAUDE + $TMUX_SESSION_WATCHDOG alive)."
    # Still ensure the LaunchAgent is loaded so launchd will respawn at login.
    # This is non-destructive — launchctl load is a no-op when already loaded.
    if [[ -f "$PLIST_PATH" ]]; then
      launchctl load "$PLIST_PATH" 2>/dev/null || true
    fi
    return 0
  fi
  if [[ ! -x "$START_SCRIPT" ]]; then
    echo "Missing $START_SCRIPT — run install.sh first." >&2
    return 1
  fi
  # Ensure LaunchAgent is loaded so launchd will respawn on next login.
  if [[ -f "$PLIST_PATH" ]]; then
    launchctl load "$PLIST_PATH" 2>/dev/null || true
  fi
  "$START_SCRIPT"
}

cmd_stop() {
  tmux kill-session -t "$TMUX_SESSION_CLAUDE" 2>/dev/null || true
  tmux kill-session -t "$TMUX_SESSION_WATCHDOG" 2>/dev/null || true

  # Clean up the bun MCP grandchildren the official telegram plugin spawned.
  # Process tree:  claude → bun (wrapper, --cwd .../telegram ...) → bun server.ts
  # Killing the tmux session only kills the claude. bun reparents to launchd
  # and keeps long-polling Telegram's getUpdates. The next `cta start` spawns
  # a fresh bun — now TWO consumers race for getUpdates, and ~half of inbound
  # messages go to the orphan with no claude listening, getting silently
  # dropped. Targeted by command-line match against the plugin path so we
  # never kill unrelated `bun server.ts` processes the user might run.
  _kill_plugin_bun
  if [[ -f "$PLIST_PATH" ]]; then
    launchctl unload "$PLIST_PATH" 2>/dev/null || true
  fi
  echo "Stopped agent (tmux + plugin MCP + LaunchAgent)."
}

# Kill the telegram plugin's bun wrapper + its server.ts child, but nothing
# else. Identifies victims by command-line match against the plugin path,
# then prunes children via pgrep -P so we don't accidentally kill an
# unrelated `bun server.ts` running in another project on this Mac.
_kill_plugin_bun() {
  local wrappers w kids k
  wrappers=$(pgrep -f "claude-plugins-official.*telegram.*start" 2>/dev/null || true)
  for w in $wrappers; do
    kids=$(pgrep -P "$w" 2>/dev/null || true)
    for k in $kids; do
      kill "$k" 2>/dev/null || true
    done
    kill "$w" 2>/dev/null || true
  done
}

# Toggle the bot's per-message ack reaction by mutating access.json.
# The plugin re-reads access.json on every request (`loadAccess()` in
# server.ts), so the change takes effect on the next inbound message —
# no bot restart needed.
#   cta config ack on   → write "ackReaction": "<DEFAULT_ACK_EMOJI>"
#   cta config ack off  → remove the "ackReaction" key entirely
# Uses python3 (ships with macOS) for JSON mutation so we don't hand-roll
# a JSON parser in bash and don't add a jq dependency.
cmd_config() {
  local sub="${1:-}"
  shift 2>/dev/null || true
  case "$sub" in
    ack)        _config_ack "${1:-}" ;;
    caffeinate) _config_caffeinate "${1:-}" ;;
    "")
      echo "Usage: cta config <ack|caffeinate> <on|off>" >&2
      return 1
      ;;
    *)
      echo "Unknown config subcommand: $sub" >&2
      echo "Usage: cta config <ack|caffeinate> <on|off>" >&2
      return 1
      ;;
  esac
}

_config_ack() {
  local val="${1:-}"
  case "$val" in
    on|off) ;;
    "")
      echo "Usage: cta config ack <on|off>" >&2
      return 1
      ;;
    *)
      echo "Invalid value: $val (expected 'on' or 'off')" >&2
      return 1
      ;;
  esac
  if [[ ! -f "$ACCESS_FILE" ]]; then
    echo "Missing $ACCESS_FILE — run install.sh first." >&2
    return 1
  fi
  local emoji=""
  [[ "$val" == "on" ]] && emoji="$DEFAULT_ACK_EMOJI"
  python3 - "$ACCESS_FILE" "$emoji" <<'PY'
import json, sys
path, val = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
if val == "":
    data.pop("ackReaction", None)
else:
    data["ackReaction"] = val
with open(path, "w") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write("\n")
PY
  chmod 600 "$ACCESS_FILE"
  if [[ "$val" == "on" ]]; then
    echo "ackReaction: $DEFAULT_ACK_EMOJI (takes effect on next message)"
  else
    echo "ackReaction: off"
  fi
}

# Returns 0 if the CLI-managed caffeinate process is alive. PID file exists
# AND that PID is currently running — guards against stale pid files left by
# `kill -9`, OS reboots, etc.
_caffeinate_alive() {
  [[ -f "$CAFFEINATE_PID_FILE" ]] || return 1
  local pid
  pid=$(cat "$CAFFEINATE_PID_FILE" 2>/dev/null) || return 1
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

# Spawn `caffeinate -i` detached from this cta process so it survives the
# command exit. `-i` blocks idle system sleep but lets the display dim — same
# semantics as Pager's CaffeinateController. We don't mirror Pager's "AC-only"
# mode: that needs a power-state watcher running continuously and cta is
# one-shot. Users who want AC-conditional behavior should use Pager.
_caffeinate_start() {
  if _caffeinate_alive; then
    echo "Already running (pid $(cat "$CAFFEINATE_PID_FILE"))."
    return 0
  fi
  mkdir -p "$(dirname "$CAFFEINATE_PID_FILE")"
  # nohup + & + disown: caffeinate keeps running after cta exits. setsid would
  # be cleaner but macOS doesn't ship it.
  nohup /usr/bin/caffeinate -i >/dev/null 2>&1 &
  local pid=$!
  disown "$pid" 2>/dev/null || true
  echo "$pid" > "$CAFFEINATE_PID_FILE"
  echo "Started caffeinate -i (pid $pid)."
}

_caffeinate_stop() {
  if ! _caffeinate_alive; then
    rm -f "$CAFFEINATE_PID_FILE"
    echo "Not running."
    return 0
  fi
  local pid
  pid=$(cat "$CAFFEINATE_PID_FILE")
  kill "$pid" 2>/dev/null || true
  rm -f "$CAFFEINATE_PID_FILE"
  echo "Stopped caffeinate (pid $pid)."
}

_config_caffeinate() {
  local val="${1:-}"
  case "$val" in
    on)  _caffeinate_start ;;
    off) _caffeinate_stop ;;
    "")
      echo "Usage: cta config caffeinate <on|off>" >&2
      return 1
      ;;
    *)
      echo "Invalid value: $val (expected 'on' or 'off')" >&2
      return 1
      ;;
  esac
}

# ─── Phase 3 pairing (one-time bootstrap secret) ────────────────────────────
# The bot is one-time-pairable via an 8-char code displayed at install time.
# In Telegram, the user sends `/pair XXXX-XXXX` to the bot — the poller claims
# this chat as MAIN_CHAT_ID and the sender as the allowlisted user, then
# consumes the code. After pairing, only the paired user can issue commands.
#
# Threat model: anyone who can see the pairing code can claim the bot before
# you do. Code lives at $STATE_DIR/pairing-code (mode 600, default $HOME/.pager)
# and is deleted on first successful pair. install.sh prints it once to stdout.
# Lost code → `cta pair-code --reset` regenerates.

# PAIRING_CODE_FILE moved to the top-of-file STATE_DIR block.

# Confusion-free alphabet: drops 0/O, 1/I/L, S/5, Z/2, B/8 — so a code copied
# from a terminal phone-photo is unambiguous. 25 chars × 8 ≈ 37 bits entropy,
# plenty for a one-time bootstrap secret that's gone in minutes.
_PAIRING_ALPHABET="ACDEFGHJKMNPQRTUVWXY34679"

_generate_pairing_code() {
  local bytes code="" abet="$_PAIRING_ALPHABET"
  # openssl rand is on every macOS; od -An -tu1 prints space-separated bytes
  bytes=$(openssl rand 16 2>/dev/null | od -An -tu1)
  for byte in $bytes; do
    [[ ${#code} -ge 8 ]] && break
    code="${code}${abet:$((byte % ${#abet})):1}"
  done
  printf '%s-%s\n' "${code:0:4}" "${code:4:8}"
}

# PAIRED_STATE_FILE moved to the top-of-file STATE_DIR block.

# cta pair — host-driven pairing. Bypasses Telegram entirely. The user types
# the chat_id (and optional user_id) they want to claim, and we write
# paired.json directly. Useful when:
#   - The inline-keyboard auto-pair flow doesn't fire (forum permission caches,
#     bot kicked before tap, etc.)
#   - The user wants deterministic setup over a magic flow
#   - Scripted / Pager-driven setup needs to skip the Telegram round-trip
# Discovery helper: `cta pair --auto` polls the Bot API for chats the bot
# has been seen in recently and prints them so the user can pick a chat_id
# without hunting through Telegram UI.
cmd_pair() {
  local sub="${1:-}"
  if [[ "$sub" == "--auto" ]]; then
    _pair_auto_discover
    return $?
  fi
  if [[ "$sub" == "--help" || -z "$sub" ]]; then
    cat <<EOF
Usage:
  cta pair <chat_id> [user_id]   Claim chat_id (negative for groups/supergroups).
                                 user_id defaults to the chat owner for DMs, or
                                 must be specified for groups (your Telegram user id).
  cta pair --auto                Scan recent Bot API updates for chats the bot
                                 has been added to and offer them to pick from.
EOF
    return 0
  fi
  local chat_id="$1"
  local user_id="${2:-}"
  if ! [[ "$chat_id" =~ ^-?[0-9]+$ ]]; then
    echo "cta pair: chat_id must be an integer (got '$chat_id')" >&2
    return 1
  fi
  if [[ -n "$user_id" ]] && ! [[ "$user_id" =~ ^[0-9]+$ ]]; then
    echo "cta pair: user_id must be a positive integer (got '$user_id')" >&2
    return 1
  fi
  # DM heuristic: positive chat_id = personal account, user_id == chat_id.
  # Groups/supergroups have negative chat_id; user_id is the operator's
  # personal Telegram user id (8-10 digits).
  if [[ -z "$user_id" ]]; then
    if [[ "$chat_id" =~ ^[0-9]+$ ]]; then
      user_id="$chat_id"
    else
      echo "cta pair: user_id is required for groups/supergroups (negative chat_id)." >&2
      echo "Hint: DM @userinfobot on Telegram to find your numeric user id." >&2
      return 1
    fi
  fi

  if [[ -f "$PAIRED_STATE_FILE" ]]; then
    local cur_chat
    cur_chat=$(jq -r '.chat_id' "$PAIRED_STATE_FILE" 2>/dev/null || echo "?")
    echo "Already paired with chat=$cur_chat. Run 'cta unpair' first to claim a new chat." >&2
    return 1
  fi

  mkdir -p "$(dirname "$PAIRED_STATE_FILE")"
  chmod 700 "$(dirname "$PAIRED_STATE_FILE")" 2>/dev/null || true
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  # umask 077 ensures the file lands at 0600 (it contains a chat_id that's
  # routable but not secret; still, defense in depth costs nothing).
  ( umask 077 && printf '{\n  "version": 1,\n  "chat_id": %s,\n  "user_id": %s,\n  "paired_at": "%s"\n}\n' \
      "$chat_id" "$user_id" "$now" > "$PAIRED_STATE_FILE" )
  echo "Paired: chat=$chat_id user=$user_id"

  # Recreate the wildcard mount if CLAUDE_CWD is set and no wildcard exists.
  # This mirrors the poller's ensureWildcardMount so host-driven pairs land
  # the user in a working state with one command.
  local cwd
  cwd=$(grep '^CLAUDE_CWD=' "$ENV_FILE" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
  if [[ -n "$cwd" && -d "$cwd" ]]; then
    if [[ -f "$MOUNT_STORE_TS" ]]; then
      local has_wildcard
      has_wildcard=$(bun run "$MOUNT_STORE_TS" list 2>/dev/null | jq -r '.mounts[] | select(.thread_id == "*") | .thread_id' 2>/dev/null)
      if [[ -z "$has_wildcard" ]]; then
        bun run "$MOUNT_STORE_TS" add '*' "$cwd" default >/dev/null 2>&1 \
          && echo "Wildcard mount auto-created: * → $cwd"
      fi
    fi
  fi
  echo "Tip: the poller picks up paired.json automatically (it watches mtime). No restart needed."
}

# Discover chats the bot has been added to by polling the Bot API for
# recent updates. Prints "<chat_id>  <title>" lines so the user can pick.
_pair_auto_discover() {
  local token
  token=$(grep '^TELEGRAM_BOT_TOKEN=' "$HOME/.claude/channels/telegram/.env" 2>/dev/null | cut -d= -f2- | tr -d '"')
  if [[ -z "$token" ]]; then
    echo "cta pair --auto: TELEGRAM_BOT_TOKEN not found in ~/.claude/channels/telegram/.env" >&2
    return 1
  fi
  # offset=-50 grabs the most recent 50 updates without consuming them
  # (Telegram only marks updates "read" when you ack a higher offset). The
  # live poller stays untouched.
  local resp
  resp=$(curl -fsS "https://api.telegram.org/bot${token}/getUpdates?offset=-50&timeout=0" 2>/dev/null)
  if [[ -z "$resp" ]] || ! echo "$resp" | jq -e '.ok' >/dev/null; then
    echo "cta pair --auto: getUpdates failed (network, token, or no recent updates)" >&2
    return 1
  fi
  echo "Recent chats the bot has seen (most-recent first):"
  echo "$resp" | jq -r '
    .result
    | map(.my_chat_member // .message // .callback_query.message // empty)
    | map({chat_id: .chat.id, title: (.chat.title // .chat.first_name // "<DM>"), type: .chat.type})
    | unique_by(.chat_id)
    | reverse
    | .[]
    | "  \(.chat_id)  [\(.type)]  \(.title)"
  '
  echo
  echo "To pair, run: cta pair <chat_id> <your_user_id>"
  echo "  (your_user_id is your numeric Telegram user id — DM @userinfobot to find it)"
}

cmd_unpair() {
  # Release the current paired chat so a new /pair (manual or auto via invite)
  # can claim a different one. Optional --keep-mounts leaves mounts.json
  # intact — useful if you're re-pairing to the same chat after testing
  # auto-pair (the mounts are still valid; only the chat_id/user_id changes).
  local keep_mounts=0
  if [[ "${1:-}" == "--keep-mounts" ]]; then keep_mounts=1; fi

  if [[ ! -f "$PAIRED_STATE_FILE" ]]; then
    echo "Not currently paired (paired.json absent)."
    return 0
  fi

  local chat_id user_id
  chat_id=$(jq -r '.chat_id' "$PAIRED_STATE_FILE" 2>/dev/null || echo "?")
  user_id=$(jq -r '.user_id' "$PAIRED_STATE_FILE" 2>/dev/null || echo "?")
  rm -f "$PAIRED_STATE_FILE"
  echo "Unpaired (was: chat=$chat_id user=$user_id)."

  if [[ "$keep_mounts" -eq 0 ]]; then
    # Wipe mounts.json so the new pair starts clean. Wildcard from install
    # is regenerated next time install.sh runs; for now, just remove all
    # entries. User can re-mount via Telegram /mount or terminal cta mount.
    if [[ -f "$MOUNT_STORE_TS" ]]; then
      # Build a fresh empty mounts.json by removing the file (mount-store
      # creates it on first add).
      rm -f "$MOUNTS_FILE"
      echo "Cleared mounts.json (use --keep-mounts to preserve next time)."
    fi
  fi

  echo "Next: re-add the bot in Telegram (auto-pair prompt fires), OR send /pair <code> using \`cta pair-code\`."
}

cmd_pair_code() {
  local mode="${1:---show}"
  case "$mode" in
    --init)
      # Create if missing. Idempotent — install.sh calls this on every run.
      if [[ -f "$PAIRING_CODE_FILE" ]]; then
        cat "$PAIRING_CODE_FILE"
        return 0
      fi
      mkdir -p "$(dirname "$PAIRING_CODE_FILE")"
      chmod 700 "$(dirname "$PAIRING_CODE_FILE")" 2>/dev/null || true
      ( umask 077 && _generate_pairing_code > "$PAIRING_CODE_FILE" )
      chmod 600 "$PAIRING_CODE_FILE"
      cat "$PAIRING_CODE_FILE"
      ;;
    --reset)
      # Force-regenerate. Used after lost code or to re-pair from scratch.
      mkdir -p "$(dirname "$PAIRING_CODE_FILE")"
      ( umask 077 && _generate_pairing_code > "$PAIRING_CODE_FILE" )
      chmod 600 "$PAIRING_CODE_FILE"
      cat "$PAIRING_CODE_FILE"
      ;;
    --show|"")
      if [[ -f "$PAIRING_CODE_FILE" ]]; then
        cat "$PAIRING_CODE_FILE"
      else
        echo "No pairing code present. Either pairing already completed, or run 'cta pair-code --reset'." >&2
        exit 1
      fi
      ;;
    *)
      echo "Usage: cta pair-code [--show | --init | --reset]" >&2
      exit 1
      ;;
  esac
}

# ─── Phase 2 mount management ───────────────────────────────────────────────
# `cta mount/umount/list` write to ~/.claude-telegram-agent/mounts.json via
# the mount-store TS lib (single source of truth for concurrency). Per-topic
# tmux sessions are spawned/killed inline so users don't need to run
# `cta start` again after a mount edit. The poller hot-reloads mounts.json
# on mtime change, so message routing follows automatically.

# Locate mount-store.ts. CTA_AGENT_DIR override lets tests point at the
# repo copy without installing.
_mount_store_path() {
  local d="${CTA_AGENT_DIR:-$INSTALL_DIR/agent}"
  echo "$d/mount-store/mount-store.ts"
}

_topic_wrapper_path() {
  local d="${CTA_AGENT_DIR:-$INSTALL_DIR/agent}"
  echo "$d/topic-wrapper.sh"
}

cmd_mount() {
  local thread_id="${1:-}" path="${2:-}" label="${3:-}"
  if [[ -z "$thread_id" || -z "$path" ]]; then
    echo "Usage: cta mount <thread_id|dm> <path> [label]" >&2
    exit 1
  fi
  if [[ ! -d "$path" ]]; then
    echo "cta mount: '$path' is not a directory" >&2
    exit 1
  fi
  # Resolve to absolute path so the mount entry doesn't depend on $PWD.
  local abs_path
  abs_path=$(cd "$path" && pwd -P)

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta mount: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  local mount_json
  if [[ -n "$label" ]]; then
    mount_json=$(bun run "$store" add "$thread_id" "$abs_path" "$label")
  else
    mount_json=$(bun run "$store" add "$thread_id" "$abs_path")
  fi
  local rc=$?
  [[ "$rc" -ne 0 ]] && exit "$rc"

  local tmux_session
  tmux_session=$(echo "$mount_json" | jq -r '.tmux_session')

  # If the poller is alive we want the topic immediately routable. Spawn
  # the per-topic tmux now; topic-wrapper.sh handles UUID + claude launch.
  #
  # tmux new-session's second positional arg is passed to /bin/sh -c, so
  # paths with spaces or shell metacharacters in $abs_path or $thread_id
  # would split across args (or execute arbitrary commands). printf %q
  # shell-escapes each before concatenation.
  if tmux has-session -t poller 2>/dev/null; then
    tmux kill-session -t "$tmux_session" 2>/dev/null || true
    local wrapper
    wrapper=$(_topic_wrapper_path)
    local quoted_cmd
    quoted_cmd=$(printf '%q ' "$wrapper" "$thread_id" "$abs_path" "$tmux_session")
    tmux new-session -d -s "$tmux_session" "$quoted_cmd"
    echo "Mounted thread $thread_id at $abs_path (tmux: $tmux_session, live)"
  else
    echo "Mounted thread $thread_id at $abs_path (tmux: $tmux_session — will start on next 'cta start')"
  fi
}

cmd_umount() {
  local thread_id="${1:-}"
  if [[ -z "$thread_id" ]]; then
    echo "Usage: cta umount <thread_id|dm>" >&2
    exit 1
  fi

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta umount: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  local removed
  removed=$(bun run "$store" remove "$thread_id")
  local rc=$?
  [[ "$rc" -ne 0 ]] && exit "$rc"

  if [[ "$removed" == "null" ]]; then
    echo "cta umount: thread $thread_id was not mounted"
    return 0
  fi

  local tmux_session
  tmux_session=$(echo "$removed" | jq -r '.tmux_session')
  tmux kill-session -t "$tmux_session" 2>/dev/null && \
    echo "Unmounted thread $thread_id (killed tmux $tmux_session)" || \
    echo "Unmounted thread $thread_id (tmux $tmux_session was not running)"
}

# Look up topic display name from topics.json (poller-maintained cache of
# forum_topic_created / forum_topic_edited service messages). Returns empty
# if topics.json is missing, paired.json is missing, the thread_id is not
# numeric, or the topic wasn't observed by the poller (e.g., created before
# bot joined — Telegram has no getForumTopic API, so pre-bot topics are
# unrecoverable). Always exits 0 — callers treat empty as "unknown."
_topic_name() {
  local thread_id="$1"
  # Non-numeric thread_ids ("dm", "*") have no forum topic by definition.
  [[ "$thread_id" =~ ^[0-9]+$ ]] || return 0
  [[ -f "$TOPICS_FILE" && -f "$PAIRED_STATE_FILE" ]] || return 0
  local chat_id
  chat_id=$(jq -r '.chat_id // empty' "$PAIRED_STATE_FILE" 2>/dev/null) || return 0
  [[ -n "$chat_id" ]] || return 0
  jq -r --arg key "${chat_id}/${thread_id}" \
    '.topics[$key].name // empty' "$TOPICS_FILE" 2>/dev/null
}

cmd_list() {
  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta list: mount-store not installed — rerun install.sh" >&2
    exit 1
  fi

  local raw
  raw=$(bun run "$store" list)

  if [[ "${1:-}" == "--json" ]]; then
    # Enrich each mount with topic_name when the poller has cached it.
    # Topic names live in a separate file (topics.json) maintained from
    # Telegram service messages; we join them here so JSON consumers
    # (Pager, scripts) get a one-stop view without a second roundtrip.
    local chat_id=""
    if [[ -f "$PAIRED_STATE_FILE" ]]; then
      chat_id=$(jq -r '.chat_id // empty' "$PAIRED_STATE_FILE" 2>/dev/null || echo "")
    fi
    local topics_arg="{}"
    if [[ -f "$TOPICS_FILE" ]]; then
      topics_arg=$(jq -c '.topics // {}' "$TOPICS_FILE" 2>/dev/null || echo "{}")
    fi
    echo "$raw" | jq \
      --arg chat_id "$chat_id" \
      --argjson topics "$topics_arg" \
      '.mounts |= map(
        . + (
          if (.thread_id | type) == "number" and ($chat_id | length) > 0 then
            { topic_name: ($topics[($chat_id + "/" + (.thread_id | tostring))].name // null) }
          else
            { topic_name: null }
          end
        )
      )'
    return
  fi

  local count
  count=$(echo "$raw" | jq '.mounts | length')
  if [[ "$count" -eq 0 ]]; then
    echo "No mounts. Add one with: cta mount <thread_id> <path>"
    return
  fi

  printf "%-10s %-20s %-15s %-50s %-12s %s\n" "THREAD" "TOPIC" "LABEL" "PATH" "TMUX" "STATUS"
  while IFS=$'\t' read -r thread_id label path tmux_session; do
    local status="dead"
    tmux has-session -t "$tmux_session" 2>/dev/null && status="alive"
    local topic
    topic=$(_topic_name "$thread_id")
    printf "%-10s %-20s %-15s %-50s %-12s %s\n" \
      "$thread_id" "${topic:--}" "${label:--}" "$path" "$tmux_session" "$status"
  done < <(echo "$raw" | jq -r '.mounts[] | [.thread_id, .label // "", .path, .tmux_session] | @tsv')
}

# `cta bind` — called from inside a running claude session (via the
# bind-telegram-topic skill or directly in a tmux pane). Captures the
# current tmux session name + pane cwd and writes a mounts.json entry so
# the poller routes <thread_id>'s messages into this very claude.
#
# Hard requirement: $TMUX must be set. We can't pipe stdin into a claude
# running in a bare terminal — same locking constraint that makes
# --session-id collide with active sessions.
cmd_bind() {
  local thread_id="${1:-}"
  local label="${2:-}"
  if [[ -z "$thread_id" ]]; then
    echo "Usage: cta bind <thread_id|dm> [label]" >&2
    echo "Run this from inside the tmux session you want to bind." >&2
    exit 1
  fi
  if [[ -z "${TMUX:-}" ]]; then
    echo "cta bind: not in a tmux session (\$TMUX is unset)." >&2
    echo "Open this claude inside tmux and re-run, or use 'cta mount <thread_id> <path>'." >&2
    exit 1
  fi

  local current_session pane_cwd
  current_session=$(tmux display-message -p '#S' 2>/dev/null || true)
  pane_cwd=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null || true)
  if [[ -z "$current_session" || -z "$pane_cwd" ]]; then
    echo "cta bind: tmux display-message returned nothing (broken tmux env?)" >&2
    exit 1
  fi
  if [[ ! -d "$pane_cwd" ]]; then
    echo "cta bind: pane cwd '$pane_cwd' is not a directory" >&2
    exit 1
  fi

  local store
  store=$(_mount_store_path)
  if [[ ! -f "$store" ]]; then
    echo "cta bind: mount-store not installed at $store — rerun install.sh" >&2
    exit 1
  fi

  # bind PINs the *current* tmux session name (whatever the user named
  # theirs) so the poller dispatches into the live claude instead of
  # spawning a fresh topic-<id> wrapper. mount-store's `add` accepts an
  # optional 4th arg that overrides the default tmux_session.
  local mount_json
  mount_json=$(bun run "$store" add "$thread_id" "$pane_cwd" "${label:-}" "$current_session")
  local rc=$?
  if [[ "$rc" -ne 0 ]]; then exit "$rc"; fi

  echo "Bound thread $thread_id → tmux $current_session (cwd: $pane_cwd)"
  echo "Future messages in thread $thread_id will be sent into this pane."
  echo "Note: this pane already has a claude running. cta does NOT respawn it;"
  echo "      messages will land via tmux send-keys into the existing prompt."
}

cmd_migrate_state() {
  # Move v0.1 state + install dirs to the v0.2 layout. Refuses to run while
  # the poller is alive — partial writes during migration would corrupt
  # mounts.json / paired.json. install.sh auto-invokes this on the first
  # upgrade after the rename; manual invocation is for operators with
  # custom layouts or interrupted migrations.
  # "Is the poller live against the dir we're about to move?" The heartbeat
  # file is touched every loop iter (~25s); if it's been updated in the last
  # 60s, something's writing to the legacy dir right now and the move would
  # corrupt state mid-write. Global pgrep would false-positive on a poller
  # that's already pointing at the new $STATE_DIR (e.g., partial migration).
  local hb="$LEGACY_STATE_DIR/heartbeat-poller"
  if [[ -f "$hb" ]]; then
    local hb_age=$(( $(date +%s) - $(stat -f %m "$hb" 2>/dev/null || echo 0) ))
    if [[ "$hb_age" -lt 60 ]]; then
      echo "cta migrate-state: poller is running against $LEGACY_STATE_DIR (heartbeat ${hb_age}s old)." >&2
      echo "Run 'cta stop' first, then re-run 'cta migrate-state'." >&2
      exit 1
    fi
  fi

  local did_state=0 did_install=0
  if [[ -d "$LEGACY_STATE_DIR" && ! -e "$STATE_DIR" ]]; then
    did_state=1
  elif [[ -d "$LEGACY_STATE_DIR" && -d "$STATE_DIR" ]]; then
    echo "cta migrate-state: both $LEGACY_STATE_DIR and $STATE_DIR exist." >&2
    echo "Merge or remove one side manually — refusing to clobber." >&2
    exit 1
  fi
  if [[ -d "$LEGACY_INSTALL_DIR" && ! -e "$INSTALL_DIR" ]]; then
    did_install=1
  elif [[ -d "$LEGACY_INSTALL_DIR" && -d "$INSTALL_DIR" ]]; then
    # Install dir is regenerated by install.sh, so a coexisting new dir is
    # almost certainly a fresh install on top of a legacy one. Safe to
    # delete the legacy install — the new one is authoritative.
    echo "cta migrate-state: legacy install dir present alongside new one; removing legacy."
    rm -rf "$LEGACY_INSTALL_DIR"
  fi

  if [[ $did_state == 0 && $did_install == 0 ]]; then
    echo "cta migrate-state: nothing to migrate."
    return 0
  fi

  # Backup manifest: a record of what moved, so a panicked operator can
  # locate files after the rename. Not a rollback script — `mv` is atomic
  # on the same filesystem (same $HOME volume), so rollback is `mv` back.
  local manifest
  manifest="$HOME/.pager-migration-$(date +%Y%m%d-%H%M%S).manifest"
  {
    echo "# pager-for-agents state migration"
    echo "# timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "# host: $(hostname)"
  } > "$manifest"

  if [[ $did_state == 1 ]]; then
    {
      echo ""
      echo "[state]"
      echo "from: $LEGACY_STATE_DIR"
      echo "to:   $STATE_DIR"
      echo "files:"
      find "$LEGACY_STATE_DIR" -type f -o -type l 2>/dev/null | sed 's|^|  |'
    } >> "$manifest"
    echo "moving state: $LEGACY_STATE_DIR → $STATE_DIR"
    # Parent must exist for mv-rename. Don't create the target dir itself
    # (mv would then place the legacy dir INSIDE the new dir).
    mkdir -p "$(dirname "$STATE_DIR")"
    if ! mv "$LEGACY_STATE_DIR" "$STATE_DIR"; then
      echo "cta migrate-state: state mv failed. Manifest at $manifest" >&2
      exit 1
    fi
  fi

  if [[ $did_install == 1 ]]; then
    {
      echo ""
      echo "[install]"
      echo "from: $LEGACY_INSTALL_DIR"
      echo "to:   $INSTALL_DIR"
    } >> "$manifest"
    echo "moving install: $LEGACY_INSTALL_DIR → $INSTALL_DIR"
    mkdir -p "$(dirname "$INSTALL_DIR")"
    if ! mv "$LEGACY_INSTALL_DIR" "$INSTALL_DIR"; then
      echo "cta migrate-state: install mv failed. Manifest at $manifest" >&2
      exit 1
    fi
  fi

  echo ""
  echo "✓ migration complete. Manifest: $manifest"
  echo "  Restart the agent: cta start"
}

cmd_help() {
  cat <<EOF
cta — claude-telegram-agent CLI

Usage:
  cta status [--json]             Show agent health (text by default, JSON for tooling)
  cta start                       Load LaunchAgent + spawn tmux sessions
  cta stop                        Kill tmux sessions + unload LaunchAgent
  cta mount <thread> <path>       Mount a project dir at a Telegram thread (or "dm")
  cta umount <thread>             Unmount; kill the topic's tmux session
  cta list [--json]               List current mounts
  cta bind <thread>               Bind the CURRENT tmux session to a thread (run from inside claude)
  cta pair-code [--init|--reset]  Show / generate the one-time Telegram pairing code
  cta pair <chat_id> [user_id]    Host-driven pairing (skip the Telegram round-trip)
  cta pair --auto                 Show chats the bot has been seen in recently
  cta unpair [--keep-mounts]      Release the paired chat so you can pair a different one
  cta config ack <on|off>         Toggle the bot's per-message ack reaction
  cta config caffeinate <on|off>  Toggle caffeinate -i (keep Mac awake)
  cta migrate-state               Move v0.1 ~/.claude-telegram-agent/ → ~/.pager/
  cta help                        This message

Reads ~/.pager/.env (CTA_STATE_DIR-overridable) for configurable tmux session names.

Pager and any other UI should call \`cta status --json\` rather than greping
\`ps\` / \`tmux ls\` / \`launchctl list\` directly. Schema is versioned; see
the header of this script for the contract.
EOF
}

main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true
  case "$cmd" in
    status)
      if [[ "${1:-}" == "--json" ]]; then
        cmd_status json
      else
        cmd_status text
      fi
      ;;
    start) cmd_start ;;
    stop)  cmd_stop ;;
    mount) cmd_mount "$@" ;;
    umount) cmd_umount "$@" ;;
    list)  cmd_list "$@" ;;
    bind) cmd_bind "$@" ;;
    pair-code) cmd_pair_code "$@" ;;
    pair) cmd_pair "$@" ;;
    unpair) cmd_unpair "$@" ;;
    config) cmd_config "$@" ;;
    migrate-state) cmd_migrate_state "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      echo "Unknown command: $cmd" >&2
      cmd_help >&2
      exit 1
      ;;
  esac
}

# Only run main when executed directly. Sourcing exposes _json_* helpers and
# command functions for the test suite without invoking anything.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
