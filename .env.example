# Path to your Claude Code working directory.
CLAUDE_CWD=$HOME/claude-home

# Claude Code Telegram plugin specifier (passed to --channels).
TELEGRAM_PLUGIN=telegram@claude-plugins-official

# tmux session names.
TMUX_SESSION_CLAUDE=claude
TMUX_SESSION_WATCHDOG=watchdog

# Network watchdog. PING_TARGET probes general internet; TELEGRAM_PING_TARGET
# probes Telegram itself so Telegram-only outages are also detected.
PING_TARGET=8.8.8.8
TELEGRAM_PING_TARGET=api.telegram.org
PING_INTERVAL=10

# Stable session UUID for `claude --session-id`. install.sh appends this
# automatically with a generated value; never commit a real one. Leave blank
# here — restart_claude.sh runs without --session-id if unset (fresh session
# every restart, no memory across reboots).
BOT_SESSION_ID=

# Append text to claude's system prompt for THIS bot's process only (argv-
# passed via --append-system-prompt; does NOT touch CLAUDE.md or other claude
# sessions). The baked-in default tells claude to emit plain text (no Markdown
# — Telegram renders ** and ## literally) and prefer short replies.
#
#   empty / unset → use the baked-in default
#   "off"         → no append (claude uses its full default system prompt)
#   any other     → use this string verbatim
#
# Case-sensitive: only lowercase "off" disables. "Off" or "OFF" are treated
# as custom text and passed to claude verbatim.
BOT_APPEND_SYSTEM_PROMPT=

# ─── F1+F2 multi-topic mode (opt-in) ─────────────────────────────────────────
# Set MULTI_TOPIC=1 to switch start_agents.sh from the v0 single-instance
# code path (one claude bound to the official plugin) to the F1+F2 path
# (our own poller + one claude per mounted topic with a custom MCP server).
#
# Topics live in ~/.claude-telegram-agent/mounts.json, managed by:
#   cta mount <thread_id> <path>     — add a topic→project binding
#   cta umount <thread_id>           — remove one
#   cta list                         — inspect
# `thread_id` is the Telegram forum topic id (positive integer) or the
# literal string "dm" for direct messages to the bot.
#
# Leave MULTI_TOPIC blank (or =0) to keep v0 behavior unchanged.
MULTI_TOPIC=

# The Telegram chat the poller listens to. For DMs with the bot, this is
# your own user_id. For a group/supergroup, it's the chat_id (negative
# number from getUpdates). Required when MULTI_TOPIC=1.
MAIN_CHAT_ID=
