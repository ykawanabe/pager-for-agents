# Path to your Claude Code working directory (the default project dir the bot
# auto-routes unmounted topics to). install.sh prompts for this.
CLAUDE_CWD=$HOME/claude-home

# Network watchdog. PING_TARGET probes general internet; TELEGRAM_PING_TARGET
# probes Telegram itself so Telegram-only outages are also detected.
PING_TARGET=8.8.8.8
TELEGRAM_PING_TARGET=api.telegram.org
PING_INTERVAL=10

# Stable session UUID for `claude --session-id`. install.sh appends this
# automatically with a generated value; never commit a real one. Leave blank
# here — the bot runs without --session-id if unset (fresh session every
# restart, no memory across reboots).
BOT_SESSION_ID=

# Append text to claude's system prompt for THIS bot's process only (argv-
# passed via --append-system-prompt; does NOT touch CLAUDE.md or other claude
# sessions). The baked-in default tells claude to emit plain text (no Markdown
# — Telegram renders ** and ## literally) and prefer short replies.
#
#   empty / unset → use the baked-in default
#   "off"         → no append (claude uses its full default system prompt)
#   any other     → use this string verbatim
#
# Case-sensitive: only lowercase "off" disables. "Off" or "OFF" are treated
# as custom text and passed to claude verbatim.
BOT_APPEND_SYSTEM_PROMPT=

# ─── Multi-topic mode ─────────────────────────────────────────────────────────
# Runs the poller + one claude daemon per mounted Telegram topic. This is the
# default and recommended mode — it works for both plain DM use and Telegram
# groups with forum topics. Topics live in $STATE_DIR/mounts.json (default
# ~/.pager/mounts.json), managed by:
#   cta mount <thread_id> <path>     — add a topic→project binding
#   cta umount <thread_id>           — remove one
#   cta list                         — inspect
# `thread_id` is the Telegram forum topic id (positive integer), the literal
# string "dm" for direct messages, or "*" for the catch-all fallback that
# auto-spawns a claude in any unmounted topic.
MULTI_TOPIC=1

# Optional. The Telegram chat the poller listens to (your user_id for a DM, or
# the negative chat_id for a group). You normally DON'T set this — pairing via
# /pair (or `cta pair`) writes ~/.pager/paired.json, which takes precedence.
# It's only an advanced override if you want to pin the chat from the env.
MAIN_CHAT_ID=
